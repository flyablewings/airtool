				</mx:VBox>
			</mx:HBox>
			<mx:HBox id="rightPanel"
					 width="70%"
					 height="100%"
					 borderStyle="solid"
					 borderColor="#6593cf">
				<mx:VBox id="topPanel"
						 label="Top Panel"
						 width="100%"
						 height="100%"
						 verticalGap="2">
					<mx:HBox width="100%" height="100%">
						<containers:SuperTabNavigator id="tabNav"
							width="100%"
							height="100%"
							scrollSpeed="25" 
						    stopScrollingEvent="{MouseEvent.MOUSE_UP}" 
						    startScrollingEvent="{MouseEvent.MOUSE_DOWN}"
							horizontalGap="0"
							dragEnabled="true"
							dragEnter="{this.dragEnterHandler(event)}"
							dragExit="{this.dragDropHandler(event)}"
							change="{this.changeTabHandler()}"
							tabRemoved="{this.tabRemoveHandler(event)}"/>
