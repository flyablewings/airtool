				var objArgs:Object = new Object();
				this.HKC31400J.readAllTables(new Array(objArgs));
			}
			public function _onResult_readAllTables(event:ResultEvent):void
			{
				var expData:Array = event.result as Array;
				
				switch (expData[0][0]["status"])
				{
					case "existdata":
						this._arrTables=expData[1];
						this.tvTables.dataProvider = this._arrTables;
						this.tvTables.labelField = "description";
						this.tvTables.data = "tablename";
						break;
					case "nodata":
						//entityDesign.allTables = new Array();
						break;
					case "error":
						this.closingMessage = true;
						var msg:HK_MsgBox = new HK_MsgBox(StyleMode.MsgError, this, "読込エラー", MsgButton.Ok);
						msg.message = "データベースに接続できません。";
						msg.cmdOk = _clickBtnEnd;
						msg.open();
						break;
				}
			}

			<!--=================================================================-->
			<!-- ビュー情報の読込処理                                            -->
			<!--=================================================================-->
			private function _start_readAllReltionship():void
			{
				var objArgs:Object = new Object();
				this.HKC31400J2.readTableRelationshipOfDatabase(new Array(objArgs));
			}
			public function _onResult_readTableRelationshipOfDatabase(event:ResultEvent):void
			{
				var expData:Array = event.result as Array;
				var e:EntityDesign = this.tabNav.selectedChild["displayObject"];				
				switch (expData[0][0]["status"])
				{
					case "existdata":						
						this._arrRelations=expData[1];		
						e.allDefaultRelations=expData[1];
						break;
					case "nodata":
						e.allDefaultRelations=new Array();
						break;
					case "error":
						this.closingMessage = true;
						var msg:HK_MsgBox = new HK_MsgBox(StyleMode.MsgError, this, "読込エラー", MsgButton.Ok);
						msg.message = "データベースに接続できません。";
						msg.cmdOk=_clickBtnEnd;
						msg.open();
						break;
				}
			}

			<!--=================================================================-->
			<!-- テーブル列情報の読込処理                                        -->
			<!--=================================================================-->
			private function _start_readTableColumns(
					tablenames:String
				):void{
				var objArgs:Object = new Object();
				objArgs["tablename"] = tablenames;
				this.HKC31400J.readTable_Columns(new Array(objArgs));
			}
			public function _onResult_readTable_Columns(
					event:ResultEvent
				):void{
				var e:EntityDesign = this.tabNav.selectedChild["displayObject"];
				var expData:Array = event.result as Array;
				var tbl:Table;
				var col:Column;
				var arrCol:Array = new Array();
				var strTablename:String = "";
				
				switch (expData[0][0]["status"])
				{
					case "existdata":
						var dic:Dictionary = new Dictionary();
						for each (var obj:Object in expData[1]) //obj is Column
						{
							var isTableLoaded:Boolean = false;
							strTablename = obj["tablename"].toString();
							if (dic[strTablename] == undefined){
								var tableDescription:String="";
								var objTable:Object
								if (this._arrTables != null && this._arrTables.length > 0){
									for each (objTable in this._arrTables){
										if (objTable["tablename"] == strTablename)	{
											tableDescription = objTable["description"];											
											break;
										}
									}
								}								

								tbl = new Table(strTablename, tableDescription);
								dic[strTablename] = tbl;
							}else{
								tbl = dic[strTablename];
							}
							col = new Column(strTablename, obj["fieldname"].toString(), obj["description"].toString());
							tbl.Columns.push(col);
						}
						for each (var obj2:Object in dic){
							e.addNewEntity(obj2 as Table);
							var t:Table = obj2 as Table;
							GlobalShare.insertColumns(t.TableName, t.Columns);							
						}
						
						//this.setAllEnabled();
						break;
					case "nodata":
						//this.setAllEnabled();
						break;
					case "error":
						this.closingMessage = true;
						var msg:HK_MsgBox = new HK_MsgBox(StyleMode.MsgError, this, "読込エラー", MsgButton.Ok);
						msg.message = "データベースに接続できません。";
						msg.cmdOk = _clickBtnEnd;
						msg.open();
						break;
				}
			}			

