			private function _start_readDataFromSql():void
			{
				var e:EntityDesign = this.tabNav.selectedChild["displayObject"];
				var objArgs:Object;
				objArgs = e.getSQLView();
				if(objArgs != null){
					mdm.showWindow("HKC31420.swf", this, null, objArgs);
				}
			}
			private function _start_ValidateSQL():void{		
				var e:EntityDesign = this.tabNav.selectedChild["displayObject"];	
				var objArgs:Object;
				objArgs = e.getSQLView();					
				this.HKC31400J.readDataFromSql(new Array(objArgs));
			}
			
			public function _onResult_readDataFromSql(event:ResultEvent):void{
				var expData:Array = event.result as Array;
				switch(expData[0][0]["status"]){
					case "existdata":
						if(isSave){
							callLater(openSaveView);
						}
						else{
							callLater(updateViewInfo);
						}
						break;
					case "nodata":
						if(isSave){
							callLater(openSaveView);
						}
						else{
							callLater(updateViewInfo);
						}
						break;
					case "error":
						this.closingMessage = false;
						var msg:HK_MsgBox = new HK_MsgBox(StyleMode.MsgError,this,"読込エラー", MsgButton.Ok);
						//msg.message = expData[0][0]["info"];
						msg.message = "SQLステートメントは無効です。 規則をチェックしてください。";
						
						if(isSave){
							msg.cmdOk = _clickBtnEnd;
						}
						msg.open();
						break;
				}
			}

