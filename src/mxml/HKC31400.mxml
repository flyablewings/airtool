			<!-- フォームが表示された時の処理                                    -->
			<!--=================================================================-->
			protected function creationCompleteHK_TitleWindow(event:FlexEvent):void
			{
				this._initForm();
				_strTitle = this.title;
				this.mdm = new HK_ModuleManager;
				
				var menu:NativeMenu = new NativeMenu();
				this._menuItemRefresh.addEventListener(Event.SELECT, refreshHandler);
				menu.addItem(this._menuItemRefresh);				
				this.accTree.contextMenu = menu;		
				
				var menuTbl:NativeMenu = new NativeMenu();
				this._menuItemAddTable.addEventListener(Event.SELECT, addTableHandler);
				this._menuItemRefreshTable.addEventListener(Event.SELECT, refreshTableHandler);
				menuTbl.addItem(this._menuItemAddTable);
				menuTbl.addItem(this._menuItemRefreshTable);
				this.tvTables.contextMenu = menuTbl;
				menuTbl.addEventListener(Event.DISPLAYING, menuTblDisplayingHandler);		
				
				//Load default designer, this designer cannot be closed
				this.addNewTabHandler(new AddTabEvent(AddTabEvent.addTab));														
			}
			
			private function addNewTabHandler(event:AddTabEvent, isLoadView:Boolean=false, viewName:String="", closable:String=SuperTab.CLOSE_ROLLOVER):void{
				cursorManager.setBusyCursor();
				var e:EntityDesign = new EntityDesign();
				if(isLoadView){
					e.addEventListener(FlexEvent.CREATION_COMPLETE, entCompleteHandler);
				}
				else{
					e.addEventListener(FlexEvent.CREATION_COMPLETE, entDefaultCompleteHandler);
				}
				e.addEventListener(AddTabEvent.addTab, newEntityAddTabHandler);
				e.addEventListener(AddTableEvent.addTable, _clickBtnShowTable);
				e.addEventListener(RemoveColumnEvent.remove, _clickBtnDeleteSelectedField);
				e.addEventListener(RemoveViewEvent.removeView, refreshViewHandler);
				e.addEventListener(SaveSuccessEvent.saveSuccess, refreshViewHandler);
				e.addEventListener(OpenSaveDialogEvent.openDialog, openDialogHandler);
				this.addTab(viewName, this.tabNav, e, isLoadView, closable);
				this.tabNav.selectedIndex = this.tabNav.numChildren - 1;
			}
			
			private function openDialogHandler(event:OpenSaveDialogEvent):void{
				var e:EntityDesign = this.tabNav.selectedChild["displayObject"];
				isSave = true;
				var objArgs:Object = e.getSQLView();	
				objArgs["C04_CD"] = this.userID;
				objArgs["Term"] = this.termID;
				var isDuplicateSelectedCols:Boolean = false;	
				//begin xungnv added
				var msg:HK_MsgBox = new HK_MsgBox(StyleMode.MsgWarning, this, "警告");
				if(objArgs["sql"] == null || objArgs["sql"].toString() == ""){					
					msg.message = "1個以上のテーブルからの1つ以上のコラムを選択してください。";
					msg.open();
					return;
				}
				var arrCols:Array = objArgs["columns"] as Array;
				for(var i:int = 0; i < arrCols.length && arrCols.length > 1; i++){
					while(i < arrCols.length - 1){
						if(arrCols[i].toString().split('.')[1] == arrCols[i+1].toString().split('.')[1]){
							isDuplicateSelectedCols = true;
							break;
						}
						i++;
					}
					if(isDuplicateSelectedCols)
						break;
				}
				if(isDuplicateSelectedCols){
					msg.message = "1つ以上のコラムが選択リストに存在しました。";
					msg.open();
					return;
				}
				//end xungnv added		
				
				mdm.showWindow("HKC31440.swf", this, null, objArgs);
			}
			
			private function _clickBtnDeleteSelectedField(event:RemoveColumnEvent):void
			{
				var e:EntityDesign = this.tabNav.selectedChild["displayObject"];
				e.deleteSelectedField();
			}
			
			private function newEntityAddTabHandler(event:AddTabEvent):void{
				this.addNewTabHandler(event);
			}
			
			private function refreshTableHandler(event:Event):void{
				this._start_readAllTables();
			}
			
			private function menuTblDisplayingHandler(event:Event):void{
				var items:Array = event.target["items"] as Array;
				if(this.tvTables.selectedIndex < 0){
					event.stopPropagation();
					for each(var obj:NativeMenuItem in items){
						if(obj.label != "リフレッシュ"){
							obj.enabled = false;
						}
						else{
							obj.enabled = true;
						}
					}
				}
				else{
					for each(var obj2:NativeMenuItem in items){
						obj2.enabled = true;
					}
				}
			}
			
			private function refreshHandler(event:Event):void{
				this._start_readAllTables();
				this.getAllViews();
			}
			
			public function getAllViews():void
			{
				var objArgs:Object=new Object();				
				this.HKC31400J3.readViewSql(new Array(objArgs));
			}

			public function _onResult_readViewSql(event:ResultEvent):void
			{	
				var expData:Array = event.result as Array;
				if(expData != null){			
					this._arrViews=expData[1];
				}
				else if(expData[0][0]["status"]=="error"){
					this.closingMessage = true;
					var msg:HK_MsgBox = new HK_MsgBox(StyleMode.MsgError, this, "読込エラー", MsgButton.Ok);
					msg.message = "データベースに接続できません。";
					msg.cmdOk=_clickBtnEnd;
					msg.open();
					return;
				}
				try{
					this.tvViews.dataProvider=this._arrViews;		
					this.tvViews.labelField="viewname";
					this.tvViews.data="definition";
				}catch(e:Error){				
				}
				initNonClosableTab();
			}
			
			private function addTableHandler(event:Event):void{
				var e:EntityDesign = this.tabNav.selectedChild["displayObject"];
				if(e.tabView.selectedIndex == 0){
					this.addTableToDiagram(this.tvTables.selectedItem["tablename"].toString());
				}
			}
			
			private function openViewHandler(event:Event):void{
				this.args = new Object();
				var item:Object = this.tvViews.selectedItem;
				
				this.args["viewname"] = item["viewname"].toString();
				this.args["definition"] = item["definition"].toString();
				
				this.addNewTabHandler(new AddTabEvent(AddTabEvent.addTab), true, this.args["viewname"]);
			}			
			
			private function entCompleteHandler(event:FlexEvent):void{
				var e:EntityDesign = this.tabNav.getChildAt(this.tabNav.selectedIndex)["displayObject"];
				e.allTables = this._arrTables;
				e.allDefaultRelations = this._arrRelations;
				cursorManager.removeBusyCursor();
				e.loadView(this.args);
			}
			
			private function entDefaultCompleteHandler(event:FlexEvent):void{
				var e:EntityDesign = this.tabNav.getChildAt(this.tabNav.selectedIndex)["displayObject"];
				e.allTables = this._arrTables;
				e.allDefaultRelations = this._arrRelations;
				cursorManager.removeBusyCursor();
			}
			
			private function removeViewHandler(event:Event):void{
				var e:EntityDesign = this.tabNav.selectedChild["displayObject"];
				var viewname:String = this.tvViews.selectedItem["viewname"].toString();
				e.removeView(viewname);
			}

