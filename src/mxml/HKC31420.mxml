creationComplete="creationCompleteHK_TitleWindow(event)" showHelpButton="true"
layout="absolute" width="900" height="450" title="データ表示" closingMessage="true" styleMode="print"
 xmlns:ns1="com.controls.*" resizable="true" storeWindowSize="true">

<hs:HK_S2Flex2Service id="HKC31400J" destination="HKC31400" owner="{this}"/>
<hs:HK_S2Flex2Service id="ReportDriverJ" destination="hkc.ReportDriver" owner="{this}"/>
<mx:Script>
    <![CDATA[
    	import mx.events.MenuEvent;
    	import mx.controls.advancedDataGridClasses.AdvancedDataGridColumn;
		import HK_Common.HK_Control.*;
		import HK_Common.HK_Control.HK_ControlCnst.*;
		import HK_Common.HK_Control.HK_ControlCnst.ReadState;
		import HK_Common.HK_Data.*
		import HK_Common.HK_S2Flex2.*;
		import mx.collections.*;
		import mx.controls.*;
		import mx.controls.dataGridClasses.*;
		import mx.core.UIComponent;
		import mx.events.FlexEvent;
		import mx.managers.PopUpManager;
		import mx.rpc.events.ResultEvent;
	
		<!--
		************************************************************
		***** Private 変数
		************************************************************
		-->
		private var mdm:HK_ModuleManager;
		private var strSQL:String;
		[Bindable]
		private var arr:Array;
		<!--
		************************************************************
		***** フォームイベント
		************************************************************
		-->
		<!--============================================================-->
		<!-- フォームが表示された時の処理                               -->
		<!--============================================================-->
		protected function creationCompleteHK_TitleWindow(event:FlexEvent):void {			
			this._initForm();
			this._start_readDataFromSql();
		}
		
		<!--============================================================-->
		<!-- GridでのKeyDownが発生したとき                              -->
		<!--============================================================-->
       	override public function keyDownCell(event:KeyboardEvent):void{
			
		}
		
	    <!--
        ************************************************************
        ***** SubForm イベント
        ************************************************************
        -->
		<!--============================================================-->
		<!-- 検索マークがクリックされた時の処理                         -->
		<!--============================================================-->
		override public function clickHelp(uicCtrl:UIComponent):void {			
			
			return;
		}
		
		<!--=============================================================-->
		<!-- 子フォームが閉じられ、自フォームへFocusが戻ってきた時の処理 -->
		<!--=============================================================-->
		override public function closeSubWindow(tlwWindow:HK_TitleWindow, uicInputControl:UIComponent) : void {			
		}
		
 		<!--
		************************************************************
		***** ボタンイベント
		************************************************************
		-->
		<!--============================================================-->
		<!-- 読込ボタンを押下した時の処理                               -->
		<!--============================================================-->
		private function _clickBtnAdd():void { 
            if (this.checkAllData() != 0){
                return;
            }
		}
		
		<!--============================================================-->
		<!-- 終了ボタンを押下した時の処理                               -->
		<!--============================================================-->
		private function _clickBtnEnd():void {
			this.close();
		}
		
		<!--
		************************************************************
		***** Private メソッド
		************************************************************
		-->
		<!--============================================================-->
		<!-- 初期化処理                                                 -->
		<!--============================================================-->
		private function _initForm():void{
			arr = 
			[
				{label: "Word", data: "Word"},
				{label: "Excel", data: "Excel"},
				{label: "CSV", data: "CSV"}
			]
 		}
 		
		<!--============================================================-->
		<!-- Gridのデータチェック処理(this.checkAllData()でも動作)     -->
		<!--============================================================-->
		override public function checkInputDataGrid(grd:HK_DataGrid,
		                                               dgcActive:HK_DataGridCell,
			                                           numRowIndex:Number,
			                                           strDataField:String) : String {
			
			return "";
		}
		
		<!--============================================================-->
		<!-- Grid:1件のレコ一ドも入力されていない場合                   -->
		<!--============================================================-->
         private function _checkIsBlankGrid():Boolean {
			return false;
         }
		
		
		<!--=================================================================-->
		<!-- 各コントロールのデータチェック処理(this.checkAllData()でも動作) -->
		<!--=================================================================-->
		override public function checkGridRemote(grd:HK_DataGrid, numRowIndex:Number, strDataField:String) : String {
			
			return "";
		}
		
		<!--============================================================-->
		<!-- [Grid]データベースとの照合終了処理                         -->
		<!--============================================================-->
		override public function checkGridRemoteData(grd:HK_DataGrid, numRowIndex:Number, strDataField:String, event:ResultEvent) : String {
			
			return "";
		}
		
		<!--
		************************************************************
		***** データベースアクセス
		************************************************************
		-->
		<!--============================================================-->
		<!-- Create sql and get data with script-->
		<!--============================================================-->
		private function _start_readDataFromSql():void{								
			this.HKC31400J.readDataFromSql(new Array(this.helpCode));
		}
		
		public function _onResult_readDataFromSql(event:ResultEvent):void{
			var expData:Array = event.result as Array;
			switch(expData[0][0]["status"]){
				case "existdata":
					var arrResult:Array = expData[1];
					var arrColumns:Array = expData[2];
					var arrColumnDescription:Array = expData[3];
					createDataGridColumn(arrColumns,arrColumnDescription);
					gv.dataProvider = arrResult;
					break;
				/* case "nodata":
					this.setAllEnabled();
					break; */
				case "nodata":
					break;
				case "error":
					this.closingMessage = false;
					var msg:HK_MsgBox = new HK_MsgBox(StyleMode.MsgError,this,"読込エラー", MsgButton.Ok);
					//msg.message = expData[0][0]["info"];
					msg.message = "SQLステートメントは無効です。 規則をチェックしてください。";
					msg.cmdOk = _clickBtnEnd;
					msg.open();
					break;
			}
		}
		
		private function createDataGridColumn(arrColumns:Array,arrDescription:Array):void
		{
			if (arrColumns.length > 0)
			{
				var arrDataColumns:Array= new Array();
				var colNew:AdvancedDataGridColumn;
				var j:int=0;
				for (var i:int=0; i < arrColumns.length; i++)
				{
					colNew=new AdvancedDataGridColumn()	
					colNew.dataField=arrColumns[i] as String;
					colNew.headerText=arrColumns[i];//["description"];
					if (arrDescription != null)
					{
						for (j=0;j<arrDescription.length;j++)
						{
							if (colNew.dataField.split("_")[0] == arrDescription[j]["description"].toString())
							{
								colNew.headerText = colNew.dataField;//arrDescription[j]["description"].toString();
								break;
							}
						}
					}
					//colNew.setStyle("headerStyleName", "headerAlign");
					colNew.wordWrap=false;
					colNew.width= 200;
					colNew.visible=true;
					arrDataColumns.push(colNew);
				}
				gv.columns=arrDataColumns;
				gv.validateDisplayList();
				gv.validateNow();
			}
		} 		
    ]]>
</mx:Script>
<mx:ApplicationControlBar width="100%" bottom="0" horizontalAlign="right">
	<hc:HK_Button	id="btnEnd" label="戻る"	focusEnabled="false"	icon2="return" functionKey="F12"
					click="_clickBtnEnd()" shortCutKey="end" tabIndex="11"/>
</mx:ApplicationControlBar>
	<hc:HK_DataGrid id="gv" left="0" right="0" top="0" bottom="40"/>

</hc:HK_TitleWindow>
