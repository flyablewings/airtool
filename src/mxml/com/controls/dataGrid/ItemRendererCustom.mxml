			public function changeHandler(event:ListEvent):void{
				if(listData.rowIndex != 0 && (value == null || value == "")){
					return;
				}				
								
				var grid:DataGrid = owner as DataGrid;
				var col:DataGridColumn = grid.columns[DataGridListData(listData).columnIndex];
				
				if(listData.rowIndex == 3){												
					if(this.selectedValue == "～"){
						_textInput.editable = true;
					}
					else{
						_textInput.editable = false;
						listData.owner["dataProvider"]["source"][5][col.dataField] = null;
						if(this.selectedValue == null ||this.selectedValue == ""){
							listData.owner["dataProvider"]["source"][4][col.dataField] = null;
						}					
						listData.owner["dataProvider"]["refresh"]();
					}						
				}
				
				var o:ComboBox = event.target as ComboBox;				
				var selectedTable:String = selectedValue.toString();
				
				if(selectedTable == null || selectedTable == ""){
					var ob:Array = (listData.owner as DataGrid).dataProvider["source"]; 
					var colDesc:String = ob[0][col.dataField];
					var oItem:Object = ob[0]["itemData"];
					
					for each(var colName:Object in oItem){
						if(colName["label"] == colDesc){
							selectedTable = colName["data"];
							this.selectedValue = selectedTable;
							break;		
						}
					}
				}
				
				if(selectedTable != null && selectedTable != ""){	
					var arrCols:Array = GlobalShare.getColumns(selectedTable) as Array;
					oArrCols = new Array();
					oArrCols.push({label: ".*", data: ".*"});
					for each(var oo:Object in arrCols){
						oArrCols.push({label: oo["Description"], data: oo["FieldName"]});							
					}
					
					var iIdx:int = int(col.dataField.replace("itemText", ""));					
					(listData.owner as DataGrid).dataProvider[1]["itemData" + iIdx] = oArrCols;
					
					if(isDblClickEntity){
						(listData.owner as DataGrid).dataProvider[1][col.dataField] = value;
						source = (listData.owner as DataGrid).dataProvider[1]["itemData" + iIdx];
						
						var tmpO:Object;
						for each(var obj1:Object in source){
							if(obj1 != null && obj1 != ""){
								if(obj1["label"] == value){
									tmpO = obj1;
									break;
