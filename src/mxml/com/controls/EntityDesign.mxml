				oArr.push({label: "~", data: "BETWEEN"});
				oArr.push({label: "始まる", data: "LIKEB"});//LIKE from beginning (LIKE 'value%')
				oArr.push({label: "含む", data: "LIKEA"});//Like all (contains) (LIKE '%value%')
				*/defaultSRC.addItem(new ItemDataCustom(operators, ItemDataCustom._ComboBox));
				
