			private function formatStringData(strSource:String):String
			{
				while (strSource.indexOf(" ") >= 0)
				{
					strSource=strSource.replace(" ", "");
				}
				return strSource;
			}

			private function replaceStringData(strSource:String, strOldValue:String, strNewValue:String):String
			{
				while (strSource.indexOf(strOldValue) >= 0)
				{
					strSource=strSource.replace(strOldValue, strNewValue);
				}
				return strSource;
			}
						
			public function loadView(objView:Object):void
			{
				cursorManager.setBusyCursor();
				this.joinOp = new Array();
				var i:int=0;
				var strTables:String="";
				_isLoadView = true;
				var arrDef:Array;				
				arrWhere = null;
				arrOrder = null;
				//get tablename,relations,columns from query===================
				//var strQuery:String="SELECT c09_facultynm.create_date, c09_facultynm.create_term, c09_facultynm.create_user FROM c09_facultynm JOIN c10_faculty ON c09_facultynm.create_date = c10_faculty.create_date LEFT JOIN c16_course ON c09_facultynm.create_date = c16_course.create_date";
				var strQuery:String=objView["definition"].toString();
				
				//Gets WHERE and ORDER BY Clauses
				arrDef = strQuery.split("WHERE");
				if(arrDef != null && arrDef.length > 1){
					arrDef = arrDef[1].toString().replace("ORDER BY", ";").split(";");
				}
				
				if(arrDef != null && arrDef.length > 1){					
					arrWhere = replaceStringData(replaceStringData(arrDef[0].toString(), "OR", ";"), "AND", ";").split(";");
					
					if(arrDef.length > 1){
						arrOrder = replaceStringData(arrDef[1].toString(), ",", ";").split(";");
					}
				}
				
				//Formats WHERE and ORDER BY Clauses
				if(arrWhere != null && arrWhere.length > 0){
					for (var iW:int = 0; iW < arrWhere.length; iW++){
						arrWhere[iW] = 
							formatStringData
							(
								replaceStringData
								(
									replaceStringData
									(
										replaceStringData(arrWhere[iW].toString(), "(", ""),								 
										")", 
										""
									),
									"::text",
									""
								)
							);
					}
				}
				
				//Identify BETWEEN Clause
				var tmpW:Array = new Array();
				var hasCount:int = 0;
				var hasPlus:Boolean = false;	
				if(arrWhere != null && arrWhere.length > 0){
					for(var x:int = 0; x < arrWhere.length; x++){
						var hasBW:Boolean = false;
						
						if(hasCount == 1){
							if(hasPlus){
								hasCount++;
								hasPlus = false;
							}
							x = x + hasCount;
							hasCount = 0;
						}
											
						if(x <= arrWhere.length - 1){
							if(arrWhere.length > 1){
								if(arrWhere[x].toString().search(">=") >= 0 && 
									(x + 1) < arrWhere.length &&
									arrWhere[x + 1].toString().search("<=") >= 0 &&
									arrWhere[x].toString().split(">=")[0] == 
									arrWhere[x+1].toString().split("<=")[0]){
										
									tmpW.push(arrWhere[x] + " AND " + arrWhere[x+1]);
									hasBW = true;
									hasCount = 1;
								}
							}
							
							if(!hasBW){
								tmpW.push(arrWhere[x]);
							}
							else{								
								if(x + 2 <= arrWhere.length - 1){
									hasPlus = true;
									tmpW.push(arrWhere[x + 2]);
								}
							}						
						}
					}
				}
				
				//Reset array of WHERE clause				
				arrWhere = tmpW;
				
				if(arrOrder != null && arrOrder.length > 0){
					for (var iO:int = 0; iO < arrOrder.length; iO++){
						arrOrder[iO] = 
							formatStringData
							(
								arrOrder[iO]
							);
					}
				}
				
				strQuery=strQuery.replace(" Order By ", ";").replace(" order by ", ";").replace(" ORDER BY ", ";");
				var arrTmp:Array=strQuery.split(';');
				if (arrTmp.length > 0)
				{
					strQuery=arrTmp[0];
				}
				strQuery=strQuery.replace(" FROM ", ";").replace(" from ", ";").replace(" From ", ";")
				strQuery=strQuery.replace(" WHERE ", ";").replace(" where ", ";").replace(" Where ", ";")
				arrTmp=strQuery.split(';');
				var arrTableNames:Array=new Array();
				var arrRelations:Array=new Array();
				if (arrTmp.length > 1)
				{
					_strColumnView=arrTmp[0];
					_strColumnView=_strColumnView.replace("SELECT ", "").replace("select ", "").replace("Select ", "");
					//_strColumnView=formatStringData(_strColumnView);
					_strColumnView=replaceStringData(_strColumnView, ",", ";")
					
					var strTmp:String=arrTmp[1];					
					var tmpOp:String = strTmp;
					while(tmpOp.indexOf("JOIN") >= 0){
						if(tmpOp.search(JoinOperator.LEFT_JOIN) >= 0){
							this.joinOp.push(JoinOperator.LEFT_JOIN);
						}
						if(tmpOp.search(JoinOperator.RIGHT_JOIN) >= 0){					
							this.joinOp.push(JoinOperator.RIGHT_JOIN);
						}
						if(tmpOp.search(JoinOperator.LEFT_JOIN) < 0 && strTmp.search(JoinOperator.RIGHT_JOIN) < 0 && strTmp.search(JoinOperator.JOIN) >= 0){
							this.joinOp.push(JoinOperator.INNER_JOIN);
						}
						tmpOp = tmpOp.replace("JOIN", "");
					}
					
					strTmp=replaceStringData(strTmp, "(", "");
					strTmp=replaceStringData(strTmp, ")", "");
					strTmp=replaceStringData(strTmp, "::text", "");
					strTmp=replaceStringData(replaceStringData(replaceStringData(strTmp, " INNER JOIN ", ";"), " Inner Join ", ";"), " inner join ", ";");
					strTmp=replaceStringData(replaceStringData(replaceStringData(strTmp, " LEFT JOIN ", ";"), " Left Join ", ";"), " left join ", ";");
					strTmp=replaceStringData(replaceStringData(replaceStringData(strTmp, " RIGHT JOIN ", ";"), " Right Join ", ";"), " right join ", ";");
					strTmp=replaceStringData(replaceStringData(replaceStringData(strTmp, " JOIN ", ";"), " Join ", ";"), " join ", ";");
					strTmp=replaceStringData(replaceStringData(replaceStringData(strTmp, " ON ", ";"), " On ", ";"), " on ", ";");
					
					arrTmp=strTmp.split(";")
					for (i=0; i < arrTmp.length; i++)
					{
						if (arrTmp[i].toString().search("=") >= 0) //relation
						{
							arrRelations.push(arrTmp[i].toString().replace(" = ", ":").replace("=", ":"));
						}
						else //table
						{
							var j:int;
							for (j=0; j < arrTableNames.length; j++)
							{
								if (arrTableNames[j].toString() == arrTmp[i].toString())
								{
									break;
								}
							}
							if (j >= arrTableNames.length)
							{
								arrTableNames.push(arrTmp[i].toString());
							}
						}
					}
					for (i=0; i < arrTableNames.length; i++)
					{
						strTables+=arrTableNames[i].toString() + ";";
					}
					if (strTables != "")
					{
						strTables=strTables.substring(0, strTables.length - 1);
					}
					strTables=formatStringData(strTables);

					_strRelationView="";
					for (i=0; i < arrRelations.length; i++)
					{
						_strRelationView+=arrRelations[i].toString() + ";";
					}
					if (_strRelationView != "")
					{
						_strRelationView=_strRelationView.substring(0, _strRelationView.length - 1);
					}
					_strRelationView=formatStringData(_strRelationView);
				}
				//=============================================================

				
				//Load Table View ===============================================
				if (strTables != "")
				{
					var objArgs:Object=new Object();
					var tablesArgs:String="";
					var arrTmpTbl:Array = strTables.split(";");
					for each(var oTbl:String in arrTmpTbl){
						tablesArgs += oTbl.split('"')[0] + ","; 
					}
					
					tablesArgs = tablesArgs.substring(0, tablesArgs.length - 1);
					
					objArgs["tablename"] = replaceStringData(strTables, ";", ",");
					objArgs["a02_viewname"] = objView["viewname"]; 
					this._strViewName = objView["viewname"];
					this.HKC31400J.readTable_Columns2(new Array(objArgs));
				}
				//==============================================================
			}

			public function _onResult_readTable_Columns2(event:ResultEvent):void//xungnv will come here to edit
			{
				var expData:Array=event.result as Array;
				var tbl:Table;
				var col:Column;
				var arrCol:Array=new Array();
				var strTablename:String="";
				var arrTables:Array;
				var tables:String;
				var objTableColum:Object = expData[3][1];
				//var arrTableNotSelected:Object = expData[2] as Array;
				
				if(expData.length > 2){
					var temp:Array = expData[2] as Array;
					if(temp.length > 1){
						arrTables =  expData[2][1] as Array;
						tables  = arrTables[0]["a02_tables"].toString();
					}
				}
				switch (expData[0][0]["status"])
				{
					case "existdata":
						dic = new Dictionary();
						_arrTable_Coumns=expData[1] as Array;
						
						var oTable:Array;
						var cols:Array = new Array();	
						if(tables != null)
							 oTable = tables.split(';');
							 
						for each (var obj:Object in _arrTable_Coumns) //obj is Column
						{
							strTablename=obj["tablename"].toString();
							if (dic[strTablename] == undefined)
							{
								var tableDescription:String="";
								var objTable:Object
								if (allTables != null && allTables.length > 0)
								{
									for each (objTable in allTables)
									{
										if (objTable["tablename"] == strTablename)
										{
											tableDescription=objTable["description"];
											break;
										}
									}
								}
								for each(var s1:String in oTable){								
									if(s1.search(strTablename) > -1){
										tbl=new Table(s1, tableDescription);
										dic[strTablename]=tbl;
										break;
									}
								}
							}
							else
							{
								tbl=dic[strTablename];
							}
							col=new Column(strTablename, obj["fieldname"].toString(), obj["description"].toString());
							
							if(tbl != null){
								tbl.Columns.push(col);
							}						
						}
						
						var isInSelectedCols:Boolean = false;						
						var tName:String;
						
						for each(var s:String in oTable){								
							for each(var obj2:Table in dic){
								//tName = obj2.Description;
								if(obj2.TableName.search(s.split('"')[0].toString()) > -1){
									obj2.TableName = s;
									addNewEntity(obj2, true, _isLoadView);
									isInSelectedCols = true;
									break;
								}
							}
							if(!isInSelectedCols)
							{	
								var dCol:Column;
								for each(var t:Object in objTableColum){
									if(s.search(t["tablename"].toString()) > -1){										
										dCol = new Column
										(
											t["tablename"].toString(),
											t["fieldname"].toString(),
											t["description"].toString(),
											"varchar",
											100
										);
										cols.push(dCol);
										for each(var cName:Object in allTables){
											if(t["tablename"].toString() == cName["tablename"].toString()){
												tName = cName["description"].toString();
												break;
											}
										}										
									}
								}										
								addNewEntity(new Table(s, tName, cols), true, _isLoadView);								
							}	
							isInSelectedCols = false;
						}
						
						loadRelationView();
						loadColumnView();					
						
						break;
					case "nodata":
						break;
					case "error":
						break;
				}
				cursorManager.removeBusyCursor();
			}	

			private function loadRelationView():void
			{
				if (_strRelationView != "")//vo day sua
				{
					var arrRelation:Array=_strRelationView.split(";");
					var i:int;
					for (i=0; i < arrRelation.length; i++)
					{
						var arrCol:Array=arrRelation[i].toString().split(":");
						if (arrCol.length == 2)
						{
							var arrStart:Array=arrCol[0].toString().split(".");
							var arrEnd:Array=arrCol[1].toString().split(".");
							if (arrStart.length == 2 && arrEnd.length == 2)
								entityView.createRealation(arrStart[0].toString(), arrStart[1].toString(), arrEnd[0].toString(), arrEnd[1].toString(), joinOp[i]);
						}
					}
				}
			}

			private function loadColumnView():void
			{
				if (_strColumnView != "")
				{
					var arrColumn:Array=_strColumnView.split(";");
					var i:int;
					var strTableDescription:String;
					var strColumnDescription:String;
					var newOp:Array = 
					[
						{label: "≦", data: "<="},
						{label: "≧", data: ">="},
						{label: "＝", data: "="},
						{label: "≠", data: "<>"},
						{label: "＜", data: "<"},						
						{label: "＞", data: ">"},						
						{label: "～", data: "BETWEEN"},
						{label: "始まる", data: "LIKEB"},
						{label: "含む", data: "LIKEA"}
					];
					
					for (i=0; i < arrColumn.length; i++)
					{
						var arrCol:Array=arrColumn[i].toString().split(".");
						if (arrCol.length == 2)
						{
							//get table description,column description
							strTableDescription=replaceStringData(formatStringData(arrCol[0].toString()), '"', '');
							if(arrCol[1].toString().indexOf("AS") >= 0){
								strColumnDescription=replaceStringData(formatStringData(arrCol[1].toString().split("AS")[1].toString()), '"', "");
							}
							else{
								strColumnDescription=arrCol[1].toString();
							}
							
							var arrW:Array = null;
							var arrO:Array = null;
							var bFound:Boolean = false;	
							var foundCount:int = 0;
							var value1:String = null;
							var value2:String = null;
							var operator:String = null;
							var order:String = null;	
							var hasBW:Boolean = false;					
							
							if(arrWhere != null){
								for each(var oW:String in arrWhere){
									if(foundCount == 0){
										operator = null;
										value1 = null;
										value2 = null;
									}
									hasBW = false;
									if(oW.split(".")[0] == formatStringData(arrCol[0])){
										
										var colInW:String;//voday
										
										
										for each(var opt:Object in newOp){//Compare and normal operators
											if(oW.search(opt["data"]) >= 0){ 
												colInW = formatStringData(oW.split(".")[1].toString().split(opt["data"])[0]);
												break;
											}
										}
										
										if(oW.search("~~") >= 0){//BETWEEN operator
											colInW = formatStringData(oW.split(".")[1].toString().split("~~")[0]);
										}									
										else if(oW.search("LIKE") >= 0){//LIKE operators
											colInW = formatStringData(oW.split(".")[1].toString().split("LIKE")[0]);
										}
										
										if(oW.search(">=") >= 0 && oW.search("<=") >= 0 &&
											colInW.split(">")[0] == formatStringData(arrCol[1].toString().split("AS")[0])){//Contains BETWEEN operator
											operator = "～";
											var valueTmp:Array = oW.split("AND");
											value1 = formatStringData(valueTmp[0].toString().split(">=")[1].toString());
											value2 = formatStringData(valueTmp[1].toString().split("<=")[1].toString());
											
											hasBW = true;
											
											break;
										} 
										else if(colInW == formatStringData(arrCol[1].toString().split("AS")[0])){
											if(oW.search("~~") >= 0){//Contains LIKE operator
												//LIKE 'value%'
												//LIKE '%value%'
												bFound = true;
												foundCount++;
												
												if(operator == null){
													var tmpS:String = 
														replaceStringData
														(	 
															formatStringData(oW.split(".")[1].toString().split("~~")[1].toString()),
															"'",
															""
														);
														
													if(tmpS.indexOf("%") > 0){																										
														operator = "始まる";
													}
													else{
														operator = "含む";
													}
												}
												if(value1 == null){
													value1 =
														replaceStringData
														(
															replaceStringData
															( 
																formatStringData(oW.split(".")[1].toString().split("~~")[1].toString()),
																"%",
																""
															),
															"'",
															""
														);
												}
												if(foundCount == 2){
													value2 = 
														replaceStringData
														(
															replaceStringData
															( 
																formatStringData(oW.split(".")[1].toString().split("~~")[1].toString()),
																"%",
																""
															),
															"'",
															""
														);	
												}
											}
											else{//Other operators
												for each(var op:Object in newOp){
													if(oW.search(op["data"]) >= 0){
														bFound = true;
														foundCount++;
														
														if(operator == null){
															operator = op["label"];
														}
														if(value1 == null){
															value1 = oW.split(op["data"])[1];
														}
														if(foundCount == 2){
															value2 = oW.split(op["data"])[1];															
														}
		
														break;			
													}
												}
											}
										}
									}
									if(foundCount == 2){
										bFound = false;
										foundCount = 0;
										break;
									}
								}
								
								if(operator != null){
									arrW = [
												{
													column: strColumnDescription, 
													operator: operator, 
													value1: value1,
													value2: value2
												}
											];
								}
							}
							
							if(arrOrder != null){
								for each(var oO:String in arrOrder){
									bFound = false;
									if(oO != ""){
										var tmpCol:String = formatStringData(oO.split(".")[1].toString().replace("ASC", "").replace("DESC", ""));
										var tmpCurCol:String = formatStringData(arrCol[1].toString().split("AS")[0]);
	
										if(oO.split(".")[0] == formatStringData(arrCol[0]) && tmpCol == tmpCurCol){
											for each(var odr:Object in orders){
												if(oO.search("ASC") < 0 && oO.search("DESC") < 0){
													bFound = true;
													order = orders[1]["label"];
													break;	
												}
												if(oO.search(odr["data"]) >= 0 && odr["data"] != ""){													
													bFound = true;
													order = odr["label"];													
													break;			
												}
											}
										}	
									}		
									
									if(bFound){
										bFound = false;
										break;
									}															
								}
								
								if(order != null){
									arrO =
									[
										{
											column:strColumnDescription,
											order:order
										}
									];
								}
							}							
							
							addNewColumnForGrid(replaceStringData(formatStringData(arrCol[1].toString().split("AS")[0].toString()), '"', ""), strColumnDescription, formatStringData(arrCol[0].toString()), strTableDescription, _lastColAdd, arrW, arrO);							
						}
					}
				}
				this.btnRemove.enabled = true;
			}

			private function getGridColumnByMousePosition(Px:int):DataGridColumn
			{
				var iCount:int=-1;
				var i:int;
				var arrColumns:Array=gridProperties.columns;
				for (i=0; i < arrColumns.length; i++)
				{
					var gridColumn:DataGridColumn=arrColumns[i] as DataGridColumn;
					if (Px > 0)
					{
						iCount++;
						Px=Px - gridColumn.width;
					}
					else
					{
						break;
					}
				}

				if (iCount >= 0)
				{
					return arrColumns[iCount] as DataGridColumn;
				}
				else
				{
					return null;
				}
			}
			
