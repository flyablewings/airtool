			public function deleteFieldOfTable(strTable:String):void
			{
				var src:ArrayCollection=gridProperties.dataProvider as ArrayCollection;
				var cols:Array=gridProperties.columns;
				var i:int=0;
				var j:int=0;
				var gridColumn:DataGridColumn;
				for (i=cols.length - 1; i >= 0; i--)
				{
					gridColumn=cols[i] as DataGridColumn;
					if (gridColumn.dataField != null && src[0].hasOwnProperty(gridColumn.dataField) == true && src[0][gridColumn.dataField] == strTable)
					{
						cols.splice(i, 1);
						if (_lastColAdd > 1)
						{
							_lastColAdd--;
						}
					}
				}

				gridProperties.columns=cols;
			}

			public function deleteSelectedTable():void
			{
				if (entityView.activeEntityPanel != null)
				{	
					//Delete table in comboBox
					var o:Object = new Object();
					o["label"] = entityView.activeEntityPanel.table.Description;
					o["data"] = entityView.activeEntityPanel.table.TableName;
					var idx:int = -1;
					for (var i:int = 0; i < oArrTable.length; i++){
						if(oArrTable[i]["data"] == o["data"] && oArrTable[i]["label"] == o["label"]){
							idx = i;
							break;
						}
					}
					if(idx != -1){
						oArrTable.splice(idx, 1);
						entityView.arrTablesAdded.splice(idx, 1);
					}
					deleteFieldOfTable(entityView.activeEntityPanel.table.Description);
					entityView.removeActiveEntityPanel();		
				}
			}

