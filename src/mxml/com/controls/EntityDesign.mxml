			private function executeQuery():void{
				cursorManager.setBusyCursor();
				isPreview = true;
				if(this.tabView.selectedIndex == 1){	
					this.btnReset.enabled = false;					
					if (this.txtSQL.text != null)
					{
						var objData:Object=new Object();
						objData["sql"]=this.txtSQL.text;
						this.HKC31400J.readDataFromSql(new Array(objData));
					}
				}
				else{					
					this.btnReset.enabled = true;
					cursorManager.removeBusyCursor();
				}				
			}
			
			public function _onResult_readDataFromSql(event:ResultEvent):void
			{				
				var expData:Array=event.result as Array;

				if (expData != null && expData[0][0]["status"] != "error")
				{
					if(this.isPreview){
						this.gridResult.dataProvider = expData[1];
						this.lblResult.text = "レコード（秒）: " + (expData[1] as Array).length;
						this.txtPreQuery.text = this.txtSQL.text;
						cursorManager.removeBusyCursor();
					}				
					else{
						if (isSave)
						{
							callLater(openSaveView);
						}
						else
						{
							callLater(updateViewInfo);
						}
					}
				}
				else{			
					cursorManager.removeBusyCursor();
					var msg:HK_MsgBox = new HK_MsgBox(StyleMode.MsgError, HK_TitleWindow(this.parentDocument), "エラー");
					msg.message = "SQLステートメントが無効です。またはデータベースに接続できません。";
					msg.open();
				}
			}	
			
			private function updateViewInfo():void
			{
				isSave=false;
				var objArgs:Object=this.getSQLView();
				var obj:Object=new Object();
				
				obj["viewname"]=_strViewName;
				obj["oldviewname"]=_strViewName;
				obj["definition"]=objArgs["sql"].toString();
				obj["a02_viewname"]=obj["viewname"]
				obj["a02_tables"]=objArgs["tables"].toString();
				obj["a02_relations"]=objArgs["relations"].toString();
				obj["a02_columns"]=objArgs["columns"].toString();
				obj["a02_oldviewname"]=obj["a02_viewname"];
				obj["C04_CD"]=this.parentDocument["userID"];
				obj["Term"]=this.parentDocument["termID"];

				this.HKC31400J.updateViewSql(new Array(obj));
			}

			public function _onResult_updateViewSql(event:ResultEvent):void
			{
				var msg:HK_MsgBox;
				try
				{
					var expData:Object=event.result;
					
					if (expData != null)
					{						
						dispatchEvent(new SaveSuccessEvent(SaveSuccessEvent.saveSuccess, this._strViewName));
						msg = new HK_MsgBox(StyleMode.MsgInfo, HK_TitleWindow(this.parentDocument), "メッセージ");
						msg.message = "ビューが正常に更新されました";
						msg.open();
					}
					else
					{
						msg = new HK_MsgBox(StyleMode.MsgError, HK_TitleWindow(this.parentDocument), "エラー");
						msg.message = "ビューを更新でエラー";
						msg.open();
					}
				}
				catch (err:Error)
				{
					msg = new HK_MsgBox(StyleMode.MsgError, HK_TitleWindow(this.parentDocument), "エラー");
					msg.message = "SQLステートメントが無効です。またはデータベースに接続できません。";
					msg.open();
				}
				cursorManager.removeBusyCursor();
			}

