				if (event.rowIndex == 0){
					/** #####  Insert Start 2009/12/08 Yamamoto. ##### */
					var strColNM:String = event.dataField;
					var intRow:int = event.rowIndex;
					if (strColNM != null){
						/** #  Insert E n d 2009/12/08 Yamamoto. ##### */
						var strValue:String=StringUtil.trim(gridProperties.dataProvider[intRow][strColNM].toString());
						if (strValue.length == 0){
							gridProperties.dataProvider[event.rowIndex][event.dataField]="";
							gridProperties.dataProvider[1][event.dataField]="";
							gridProperties.dataProvider[2][event.dataField]="";
						}
					}
				}
			}

