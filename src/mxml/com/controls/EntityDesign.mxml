					col=gridProperties.columns[i] as DataGridColumn;
					//src[1] = row of column name
					//src[0] = row of table name
					//src[2] = row of order by
					//src[3] = row of condition expression
					//src[4] = row of condition value1
					//src[5] = row of condition value2
					
					//Get column decription					
					if(src[1].hasOwnProperty(col.dataField) && src[1][col.dataField] != null && src[1][col.dataField] != ""){					
						strColumnDescription = src[1][col.dataField].toString().replace("\r\n", "");
						if(strColumnDescription == ".*"){							
							for each(var oCol:Object in aSrc){
								if(oCol["label"] == src[0][col.dataField]){
									strColumnDescription = "\"" + oCol["label"] + "\".*";
									break;		
								}
							}
						}
					}
					else if(src[0][col.dataField] != null && src[0][col.dataField] != ""){ 
						strColumnDescription = ".*";
						if(strColumnDescription == ".*"){							
							for each(var oCol1:Object in aSrc){
								if(oCol1["label"] == src[0][col.dataField]){
									strColumnDescription = "\"" + oCol1["label"] + "\".*";
									break;		
								}
							}
						}
					}
					else{
						strColumnDescription = "";
					}
					//Get table description
					if(src[0].hasOwnProperty(col.dataField) && src[0][col.dataField] != null && src[0][col.dataField] != ""){
						strTableDescription = src[0][col.dataField].toString();
					}
					else{
						strTableDescription = "";
					}
					
					strTmp = strTableDescription + strColumnDescription;
					
					//Get OrderBy
					if (src[2].hasOwnProperty(col.dataField) && src[2][col.dataField] != null 
					&& src[2][col.dataField] != undefined && src[2][col.dataField] != ""
					&& src[1][col.dataField] != null  && src[1][col.dataField] != undefined 
					&& src[1][col.dataField] != ".*" && src[1][col.dataField] != "")
					{
						var arrOrder:Array = src[2]["itemData"] as Array;
						for each(var order:Object in arrOrder){
							if(order["label"] != "" && order["label"] == src[2][col.dataField]){
								strOrderBy = order["data"].toString();
								break;		
							}
						}
					}
					else
					{
						strOrderBy = "";
					}						
					//Get Where condition
					if(src[3].hasOwnProperty(col.dataField) && src[3][col.dataField] != null && src[3][col.dataField] != "" 
						&& src[4].hasOwnProperty(col.dataField) && src[1][col.dataField] != null && src[1][col.dataField] != "" 
						&& src[1][col.dataField] != undefined && src[1][col.dataField] != ".*"){
						
						var ops:Array = src[3]["itemData"] as Array;
						var strOp:String = "";						
						var cond1:String = src[4][col.dataField] == null ? '' : src[4][col.dataField]; 
						var cond2:String = src[5][col.dataField] == null ? '' : src[5][col.dataField];
						
						for each(var op:Object in ops){
							if(src[3][col.dataField] == op["label"]){
								strOp = op["data"];								
								break;
							}
						} 	
						
						if(strOp == "BETWEEN"){						
							strWhere =  _objColumnSelectedInfo[strTmp] + " " + 
										strOp + " " + 
										cond1 + " AND " +
										cond2;
						}
						else if(strOp == "LIKEB"){
							strWhere =  _objColumnSelectedInfo[strTmp] + " " + 
										strOp.substring(0, strOp.length - 1) + " '" + 
										cond1 + "%'";
						}
						else if(strOp == "LIKEA"){
							strWhere =  _objColumnSelectedInfo[strTmp] + " " + 
										strOp.substring(0, strOp.length - 1) + " '%" + 
										cond1 + "%'";
						}
						else{
							strWhere =  _objColumnSelectedInfo[strTmp] + " " + 
										strOp + " " + 
										cond1;
						}
						
						if(strOp != "BETWEEN"){
							if(src[5].hasOwnProperty(col.dataField) && src[5][col.dataField] != null
							 && src[5][col.dataField] != undefined  && src[5][col.dataField] != ""){								
								if(strOp == "LIKEA"){
									strOp = strOp.substring(0, strOp.length - 1);
									strWhere += " OR\n\t" + 
										_objColumnSelectedInfo[strTmp] + " " + 
										strOp + " '" + 
										cond2 + "%'";
								}
								else if(strOp == "LIKEB"){
									strOp = strOp.substring(0, strOp.length - 1);
									strWhere += " OR\n\t" + 
										_objColumnSelectedInfo[strTmp] + " " + 
										strOp + " '%" + 
										cond2 + "%'";
								}
								else{
									strWhere += " OR\n\t" + 
										_objColumnSelectedInfo[strTmp] + " " + 
										strOp + " " + 
										cond2;
								}
							}						
						}
						
						if(strWhere != ""){
							arrWhere.push(strWhere);
						}
					}
						
					if(src[0].hasOwnProperty(col.dataField) && src[1][col.dataField] != null && src[1][col.dataField] != ""){												
						if (strTmp.length > 0 || strColumnDescription.indexOf(".*") > -1){
							var t:String = "";//Table name
							var c:String = "";//Column name
							if(strColumnDescription.indexOf(".*") < 0){
								if(_objColumnSelectedInfo.hasOwnProperty(strTmp)){
									arr0.push(_objColumnSelectedInfo[strTmp] + " AS \"" + strColumnDescription + "\"");
								}
								else{
									var found:Boolean = false;
									for each(var oT:Object in aSrc){
										if(oT["label"] == src[0][col.dataField]){
											t = "\"" + oT["label"] + "\"";
											break;
										} 
									}
									
									for(var k:int = 0; k < gridProperties.columnCount; k++){
										var aSrcC:Array = src[1]["itemData" + k] as Array;
										for each(var oC:Object in aSrcC){
											if(oC["label"] == src[1][col.dataField]){
												c = oC["data"].toString();
												found = true;
												break;
											}
										}
										
										if(found){
											break;
										}
									}
									
									if(arrWhere[i] != null && arrWhere[i].toString().search("undefined") >= 0){
										arrWhere[i] = arrWhere[i].toString().replace("undefined", t + "." + c);
									}
									
									arr0.push(t + "." + c + " AS \"" + strColumnDescription + "\"");
								}
							}
							else{
								arr0.push(strColumnDescription);
							}
							
							for each(var oTbl:Object in aSrc){
								if(oTbl["label"] == src[0][col.dataField]){
									strTableName = oTbl["data"].toString() + " \"" + oTbl["label"] + "\"";
									break;		
								}
							}
							
							if(arrTables.indexOf(strTableName) < 0){
								arrTables.push(strTableName);
							}
							if (strOrderBy != "")
							{
								if(_objColumnSelectedInfo[strTmp] == undefined){
									arr2.push(t + "." + c + " " + strOrderBy);
								}
								else{
									arr2.push(_objColumnSelectedInfo[strTmp] + " " + strOrderBy);
								}
							}
						}	
					}
					for each(var ep:EntityPanel in this.entityView.entityPanels){								
						var ePanel:EntityPanel = ep;
						if (arr1.indexOf(ePanel.tableName + "\"" + ePanel.table.Description + "\"~" +  ePanel.x + 
													":" + 
													  ePanel.y +
													"$" +
													  ePanel.width +
													":" +
													  ePanel.height) < 0)
						{
							arr1.push
							(
								ePanel.tableName + "\"" + ePanel.table.Description + "\"~" +  ePanel.x + 
													":" + 
													  ePanel.y +
													"$" +
													  ePanel.width +
													":" +
													  ePanel.height
						    );							
						}					
					}
				}

				strTmp="";
				var count:int = 0;
				for each (var str:String in arr0)
				{
					var newColDesc:String = "";
					if(str.indexOf(".*") < 0){
						newColDesc = getColumnDescription
							(
								replaceStringData(formatStringData(str.split("AS")[1]), '"', ""), 
								arr0, 
								0
							);
					}else{
						newColDesc = str;						
					}
					
					if(str.indexOf(".*") < 0){
						arr0[count] = str.split("AS")[0] + " AS \"" + newColDesc + "\"";
					}
					else{
						arr0[count] = str;
					}
					
					count++;	
				}
				
				for(var z:int = 0; z < arr0.length; z++){
					if(arr0[z].toString().indexOf("_0") >= 0){
						arr0[z] = arr0[z].toString().split("_0")[0] + "\"";
					}
				}
				
				for each(var str1:String in arr0){					
					if(str1.indexOf(".*") >= 0){						
						for each(var tbls:String in arr1){
							var desc:String = replaceStringData(str1.split('.')[0], '"','');
							if(tbls.indexOf(desc) >= 0){
								var colsDesc:Array = GlobalShare.getColumns(tbls.split('"')[0]) as Array;
								for each(var objCol:Object in colsDesc){
									strTmp += "\n\t\"" + desc + "\"." + objCol["FieldName"] + " AS \"" + objCol["Description"] + "\",";			
								}		
							}
						}						
					}				
					else{
						strTmp += "\n\t" + str1 + ",";
					}										
				}
				
				if(!arr0.length == 0)
					strSql=strSelectTemplate.replace("{0}", strTmp.substr(0, strTmp.length - 1));

				var arrRelation:Array=new Array();				
				var arrTmp:Array = this.entityView.relationManager.relationships;
				
				if (arrTmp != null && arrTmp.length > 0)
				{
					for (var j:int=0; j < arrTmp.length; j++)
					{
						var relation:IRelationRenderer=arrTmp[j];
						var obj:Object=new Object;
						obj["primaryTableName"]=relation.entitypoint1.entity.entityPanel.tableName; 
						obj["primaryTableDesc"]=relation.entitypoint1.entity.entityPanel.table.Description;
						obj["primaryTableColumn"]=relation.entitypoint1.columnName;
						obj["foreignTableName"]=relation.entitypoint2.entity.entityPanel.tableName;
						obj["foreignTableDesc"]=relation.entitypoint2.entity.entityPanel.table.Description;
						obj["foreignTableColumn"]=relation.entitypoint2.columnName;
						obj["joinOperator"] = relation.entitypoint1.joinOperator;
						arrRelation.push(obj);
					}
				}

				strTmp=getStrSQLAfterFrom(arrTables, arrRelation);
				strSql=strSql.replace("{1}", strTmp);
				strOrderBy="";				
				
				if(arrWhere.length > 0){
					strSql += "\nWHERE";
					if(arrWhere.length > 1){
						for each(var tmpStr:String in arrWhere){
							strSql += "\n\t(" + tmpStr + ") AND";
						}
						strSql = strSql.substring(0, strSql.length - 3);
					}
					else{
						strSql += "\n\t" + arrWhere[0];
					}
				}
				
				if (arr2.length > 0)
				{					
					for (i=0; i < arr2.length; i++)
					{
						if (strOrderBy == "")
						{
							strOrderBy+="\nORDER BY";
						}
						strOrderBy += "\n\t" + arr2[i].toString() + ",";
					}
					strSql+=strOrderBy.substr(0, strOrderBy.length - 1);
				}

				var objAgrs:Object=new Object();
				objAgrs["sql"]=strSql;
				objAgrs["columns"]=arr0;
				//Begin xungnv added
				var table:String = "";
				for each(var s:String in arr1){
					table += s + ";";
				}
				objAgrs["relations"] = arrRelation;
				objAgrs["tables"] = table.substring(0, table.length - 1);
				
				//End xungnv added
				return objAgrs;
			}
			
			private function getColumnDescription(columnDesc:String, tables:Array, idx:int = 0):String{				
				var isDup:Boolean = false;
				var newColDesc:String = "";
				
				for(var i:int = 0; i < tables.length; i++){
					if(columnDesc.indexOf(".*") < 0 && tables[i].toString().indexOf(".*") < 0){						
						if(replaceStringData(formatStringData(tables[i].toString().split("AS")[1]), '"', "") == columnDesc){
							isDup = true;				
							
							if(columnDesc.indexOf("_") < 0){
								newColDesc = columnDesc + "_" + idx.toString();
							}
							else{
								newColDesc = columnDesc.split("_")[0] + "_" + idx.toString();
							}
							
							idx++;
						}
					}
					if(isDup){
						break;
					}
				}
				
				if(isDup){					
					return getColumnDescription(newColDesc, tables, idx);
				}
				else{
					return columnDesc;
				}
			} 

			private function getStrSQLAfterFrom(arrTable_Selected:Array, arrRelation:Array):String
			{
				var strReturn:String="";
				var strPrimaryTableName:String;
				var strForeignKeyTable:String;
				var strOnCondition:String;
				var i:Number;
				var iRelationNumberIsUsed:Number=0;
				var iCount:Number=0;
				var arrRelationWithOnCondition:Array;
				var arrUsedTable:Array=new Array();
				var tmparrTable_Selected:Array = new Array();
				
				if (arrTable_Selected.length == 1)
				{
					return arrTable_Selected[0];
				}
				else{
					for each(var s:String in arrTable_Selected){
						tmparrTable_Selected.push(s);
					}
				}
				arrRelationWithOnCondition=createTableRelationWithOnCondition(arrRelation);
				for (i=0; i < arrRelationWithOnCondition.length; i++)
				{
					strPrimaryTableName=arrRelationWithOnCondition[i]["primaryTableDesc"].toString();
					strForeignKeyTable=arrRelationWithOnCondition[i]["foreignTableDesc"].toString();
					strOnCondition=arrRelationWithOnCondition[i]["onCondition"].toString();
					
					if (strReturn == "")
					{
						strReturn= arrRelation[i]["primaryTableName"] + " \"" + strPrimaryTableName + "\" " + 
									arrRelation[i]["joinOperator"] + " " + 
									arrRelation[i]["foreignTableName"] + " \"" + strForeignKeyTable + "\"" + 
									strOnCondition;
						arrUsedTable.push(arrRelation[i]["primaryTableName"] + " \"" + strPrimaryTableName + "\"");
						arrUsedTable.push(arrRelation[i]["foreignTableName"] + " \"" + strForeignKeyTable + "\"");
						iCount++;
							//break;	
					}
					else
					{
						if (checkUsedTable(arrUsedTable, arrRelation[i]["primaryTableName"] + " \"" + strPrimaryTableName + "\"") == true)
						{
							if (checkUsedTable(arrUsedTable, arrRelation[i]["foreignTableName"] + " \"" + strForeignKeyTable + "\"") == false)
							{
								strReturn="(" + strReturn + ") " + arrRelation[i]["joinOperator"] + " " + arrRelation[i]["foreignTableName"] + " \"" + 
								strForeignKeyTable + "\"" + strOnCondition;
								arrUsedTable.push(arrRelation[i]["foreignTableName"] + " \"" + strForeignKeyTable + "\"");
								iCount++;
									// break;
							}
						}
						else
						{
							if (checkUsedTable(arrUsedTable, arrRelation[i]["foreignTableName"] + " \"" + strForeignKeyTable + "\"") == true)
							{
								strReturn="(" + strReturn + ") " + arrRelation[i]["joinOperator"] + " " + arrRelation[i]["primaryTableName"] + " \"" + 
								strPrimaryTableName + "\"" + strOnCondition;
								arrUsedTable.push(arrRelation[i]["primaryTableName"] + " \"" + strPrimaryTableName + "\"");
								iCount++;
									// break;
							}
						}
					}					
				}
				for (i=0; i < arrTable_Selected.length; i++) //add table have no realation
				{
					//xungnv edited from split
					if (arrUsedTable.indexOf(arrTable_Selected[i].toString().split('~')[0]) < 0)
					{
						if (strReturn != "")
						{
							strReturn+=",\n\t";
						}
						strReturn+=arrTable_Selected[i];	
					}
				}
				return strReturn;
			}

			private function createTableRelationWithOnCondition(arrRelation:Array):Array
			{
				var arrTableRelationWithOnCondition:Array=new Array();
				var i:Number;
				var j:Number;
				//create new arrTableRelation with primaryTableName column and foreignKeyTable column
				for (i=0; i < arrRelation.length; i++)
				{
					for (j=0; j < arrTableRelationWithOnCondition.length; j++)
					{
						if (arrRelation[i]["primaryTableName"] == arrTableRelationWithOnCondition[j]["primaryTableName"] && 
						arrRelation[i]["foreignTableName"] == arrTableRelationWithOnCondition[j]["foreignTableName"] &&
						arrRelation[i]["primaryTableDesc"] == arrTableRelationWithOnCondition[j]["primaryTableDesc"] &&
						arrRelation[i]["foreignTableDesc"] == arrTableRelationWithOnCondition[j]["foreignTableDesc"])
						{
							break;
						}
					}
					if (j >= arrTableRelationWithOnCondition.length)
					{
						var obj:Object=new Object();
						obj["primaryTableDesc"]=arrRelation[i]["primaryTableDesc"];
						obj["foreignTableDesc"]=arrRelation[i]["foreignTableDesc"];
						obj["primaryTableName"]=arrRelation[i]["primaryTableName"];
						obj["foreignTableName"]=arrRelation[i]["foreignTableName"];
						arrTableRelationWithOnCondition.push(obj);
					}
				}

				//apend OnCondition
				var strOnCondition:String;
				for (i=0; i < arrTableRelationWithOnCondition.length; i++)
				{
					strOnCondition="";
					for (j=0; j < arrRelation.length; j++)
					{
						if ((arrTableRelationWithOnCondition[i]["primaryTableName"] == arrRelation[j]["primaryTableName"] && 
							 arrTableRelationWithOnCondition[i]["primaryTableDesc"] == arrRelation[j]["primaryTableDesc"] && 
							 arrTableRelationWithOnCondition[i]["foreignTableName"] == arrRelation[j]["foreignTableName"] && 
							 arrTableRelationWithOnCondition[i]["foreignTableDesc"] == arrRelation[j]["foreignTableDesc"]) || 
							 (arrTableRelationWithOnCondition[i]["primaryTableName"] == arrRelation[j]["foreignTableName"] && 
							 arrTableRelationWithOnCondition[i]["primaryTableDesc"] == arrRelation[j]["foreignTableDesc"] && 
							 arrTableRelationWithOnCondition[i]["foreignTableName"] == arrRelation[j]["primaryTableName"] && 
							 arrTableRelationWithOnCondition[i]["foreignTableDesc"] == arrRelation[j]["primaryTableDesc"]))
						{
							if (strOnCondition == "")
							{
								strOnCondition+=" ON\n\t";
							}
							else
							{
								strOnCondition+=" AND\n\t";
							}
							strOnCondition+="\"" + arrRelation[j]["primaryTableDesc"].toString() + "\"." + arrRelation[j]["primaryTableColumn"].toString() + " = \"" + 
							arrRelation[j]["foreignTableDesc"].toString() + "\"." + arrRelation[j]["foreignTableColumn"].toString();
							arrTableRelationWithOnCondition[i]["onCondition"]=strOnCondition;
						}
					}
				}
				return arrTableRelationWithOnCondition;
			}

			private function checkUsedTable(arrUsedTable:Array, strTable:String):Boolean
			{
				var i:Number;
				for (i=0; i < arrUsedTable.length; i++)
				{
					if (arrUsedTable[i].toString() == strTable)
					{
						return true;
					}
				}
				return false;
			}

