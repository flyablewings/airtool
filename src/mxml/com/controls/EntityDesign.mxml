			public function removeView(viewname:String=""):void{
				cursorManager.setBusyCursor();
				var objArgs:Object=new Object();
				if(viewname == ""){
					objArgs["viewname"]=this._strViewName;
				}
				else{
					objArgs["viewname"]=viewname;
					this._strViewName = viewname;
				}
				this.HKC31400J.deleteViewSql(new Array(objArgs));				
			}
			
			public function _onResult_deleteViewSql(event:ResultEvent):void
			{
				var expData:Object = event.result;
				var msg:HK_MsgBox;
				if(expData != null){
					this.resetDesigner();
					cursorManager.removeBusyCursor();
					msg = new HK_MsgBox(StyleMode.MsgInfo, HK_TitleWindow(this.parentDocument), "削除するビュー");
					msg.message = "ビューが正常に削除された";
					msg.open();																
					dispatchEvent(new RemoveViewEvent(RemoveViewEvent.removeView));					
				}
				else{
					cursorManager.removeBusyCursor();
					msg = new HK_MsgBox(StyleMode.MsgError, HK_TitleWindow(this.parentDocument), "削除するビュー");
					msg.message = "ビューを削除でのエラー";
					msg.open();
				}
			} 
			
			private function checkExistViewNameSql():void{				
				var obj:Object = new Object();
				obj["viewname"] = _strViewName;
				
				var arr:Array = new Array();
				arr.push(obj);
				
				this.HKC31400J.checkExistViewNameSql(arr);
			}
			
			public function _onResult_checkExistViewNameSql(event:ResultEvent):void{
				if(event.result == 1){
					this.updateViewInfo();
				}
				else{
					this.openSaveView();
				}				
			}
			
			public function btnViewAction_Click():void
			{				
				isPreview = false;
				if (_strViewName != "")
				{
					isSave = false;
					cursorManager.setBusyCursor();
					checkExistViewNameSql();					
				}
				else
				{
					isSave = true;
					openSaveView();
				}				
			}
			
			public function set dropTarget(value:DisplayObject):void{
				this._dropTarget = value;
			}
			
			public override function get dropTarget():DisplayObject{
				return this._dropTarget;
			}
			
			public function clickExecuteQuery():void{				
				this.tabView.selectedIndex = 1;				
				this.executeQuery();				
			}
		]]>
	</mx:Script>
