			private function onGridMouseUp(event:MouseEvent):void
			{
				//process after dragdrop
				var itemRenderer:DataGridItemRenderer=event.target as DataGridItemRenderer;
				if (itemRenderer != null)
				{
					var gridColumn:DataGridColumn=getGridColumnByMousePosition(event.stageX);
					if (gridColumn != null)
					{
						var _myIndexDragDrop:int=gridProperties.columns.indexOf(gridColumn);
						if (_myIndexDragDrop > 0 && isDrag)
						{
							var strFirstColumnName:String=EntityControl._firstColumnName;
							var strFirstTableName:String=EntityControl._firstTableName;
							var strFirstColumnDescription:String=EntityControl._firstColumnDescription;
							var strFirstTableDescription:String=EntityControl._firstTableDescription;
							if (strFirstColumnName != null && strFirstColumnName != "")
							{
								addNewColumnForGrid(strFirstColumnName, strFirstColumnDescription, strFirstTableName, strFirstTableDescription, _myIndexDragDrop);
								EntityControl._firstColumnName="";
								EntityControl._firstTableName="";
								EntityControl._firstColumnDescription="";
								EntityControl._firstTableDescription="";
							}
							isDrag = false;
						}
					}
				}
			}

