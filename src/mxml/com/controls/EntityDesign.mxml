			//xungnv added parameter isLoadView
			public function addNewEntity(tbl:Table, createRealtionFromDatabase:Boolean=true, isLoadView:Boolean = false):void
			{
				entityView.addNewEntity(tbl, createRealtionFromDatabase, isLoadView);				
				GlobalShare.insertColumns(tbl.TableName, tbl.Columns);
				
				//Loading table				
				var contain:Boolean = false;
				for each(var item:Object in oArrTable){
					if(item["label"].toString() == tbl.Description){
						contain = true;
						break;
					}					
				}
								
				var ob:Object = new Object();
				if(!contain){
					ob["label"] = tbl.Description;
					ob["data"] = tbl.TableName;	
					oArrTable.push(ob);	
				}
				
				gridProperties.dataProvider["source"][0]["itemData"] = oArrTable;
			}

			public function addNewEntityByColumns(strTableName:String, columns:Array):void
			{
				var tableDescription:String="";
				var objTable:Object;
				if (allTables != null && allTables.length > 0)
				{
					for each (objTable in allAddedTables)
					{
						if ((objTable as Table).TableName == strTableName)
						{
							tableDescription=(objTable as Table).Description;
							break;
						}
					}
				}
				entityView.addNewEntityByColumns(strTableName, tableDescription, columns);
			}

			private function onDblClickFieldEntity(event:FieldEvent):void
			{
				var col:Column=event.value as Column;
				var strFieldName:String=col.FieldName;
				var strFieldDescription:String=col.Description;
				var strTableName:String=col.TableName;
				var tableDescription:String=col.TableDescription;
				
				addNewColumnForGrid(strFieldName, strFieldDescription, strTableName, tableDescription, _lastColAdd);				
			}
			
			private function getDataField(index:int):String{
				var isDup:Boolean = false;
				for(var i:int = 0; i < gridProperties.columnCount; i++){					
					if((gridProperties.columns[i] as DataGridColumn).dataField == "itemText" + index){
						isDup = true;						
						index++;	
						break;					
					}
				}
				
				if(isDup){
					return getDataField(index);
				}
				else{
					return "itemText" + index;
				}
			}

			private function addNewColumnForGrid(strFieldName:String, strFieldDescription:String, strTableName:String, strTableDescription:String, index:int,
			oWhere:Array = null, oOrder:Array = null):void
			{
				var src:ArrayCollection=gridProperties.dataProvider as ArrayCollection;
				var cols:Array=gridProperties.columns;
				var newCols:Array=new Array();
				var gridcol:DataGridColumn=new DataGridColumn("");
				var tmpIndex:int = (index + 10);				
				var fieldTmp:String = getDataField(tmpIndex);
				
				gridcol.dataField=fieldTmp;
				gridcol.headerText="";
				gridcol.width=120;
				gridcol.setStyle("textAlign", "left");
				gridcol.itemEditor = new ClassFactory(com.controls.dataGrid.ItemRendererCustom);
				gridcol.editorDataField = "newData";
				//gridcol.setStyle("backgroundColor", 0xA2A1A1);
				cols.splice(index - 1, 0, gridcol);
				
				_lastColAdd++;
				
				gridProperties.columns=cols;
				
				if(strFieldDescription.search('_') >= 0){
					strFieldDescription = strFieldDescription.split('_')[0];
				}
				strTableDescription = this.getTableDescription(strTableDescription, this.oArrTable);
				
				
				gridProperties.dataProvider[0][fieldTmp] = strTableDescription;
				gridProperties.dataProvider[1][fieldTmp] = strFieldDescription;	
				
				if(oWhere != null){//Has WHERE clause
					gridProperties.dataProvider[3][fieldTmp] = oWhere[0]["operator"];
					gridProperties.dataProvider[4][fieldTmp] = oWhere[0]["value1"];
					gridProperties.dataProvider[5][fieldTmp] = oWhere[0]["value2"];
				}
				
				if(oOrder != null){//Has ORDER BY clause
					gridProperties.dataProvider[2][fieldTmp] = oOrder[0]["order"];
				}				
	
				_objColumnSelectedInfo[(strTableDescription + strFieldDescription).replace("\r\n", "")] = "\"" + strTableDescription + "\"." + strFieldName;
			}
		
			private function getTableDescription(tableDesc:String, tables:Array, idx:int = 1):String{				
				var contain:Boolean = false;
				var newTableDesc:String = "";
				if(tables.length != 0){
					for(var i:int = 0; i < tables.length; i++){
						if(tableDesc == tables[i]["label"]){
							contain = true;
							break;
						}				
					}
					
					if(!contain){
						idx = int(tableDesc.split('_')[1]) - 1;					
						
						if(idx != 0){
							newTableDesc = tableDesc.split('_')[0] + "_" + idx;				
						}	
						else{
							newTableDesc = tableDesc.split('_')[0]
						}
														
						return getTableDescription(newTableDesc, tables, idx);
					}
					else{
						return tableDesc;
					}
				}
				else{
					return tableDesc;
				}				
			} 
