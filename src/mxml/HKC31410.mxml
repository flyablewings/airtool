<hc:HK_TitleWindow showHelpButton="true" layout="absolute" width="244" height="325"
title="テーブルリスト" closingMessage="true" styleMode="help" 
xmlns:mx="http://www.adobe.com/2006/mxml" 
xmlns:hc="HK_Common.HK_Control.*"
xmlns:hs="HK_Common.HK_S2Flex2.*"
xmlns:newList="com.controls.list.*"
xmlns:ns1="com.controls.*"
creationComplete="creationCompleteHK_TitleWindow(event)" resizable="true" storeWindowSize="true">

<mx:Script>
    <![CDATA[
    	import com.objects.data.Table;
    	import com.objects.data.Column;
    	import mx.rpc.soap.WebService;
    	import mx.rpc.events.FaultEvent;
		import HK_Common.HK_Control.*;
		import HK_Common.HK_Control.HK_ControlCnst.*;
		import HK_Common.HK_Control.HK_ControlCnst.ReadState;
		import HK_Common.HK_Data.*
		import HK_Common.HK_S2Flex2.*;
		import mx.collections.*;
		import mx.controls.*;
		import mx.controls.dataGridClasses.*;
		import mx.core.UIComponent;
		import mx.events.FlexEvent;
		import mx.managers.PopUpManager;
		import mx.rpc.events.ResultEvent;
	
		<!--
		************************************************************************
		***  Private 変数
		************************************************************************
		-->
		private var mdm:HK_ModuleManager;
		
		<!--
		************************************************************************
		***  フォームイベント
		************************************************************************
		-->
		<!--=================================================================-->
		<!-- フォームが表示された時の処理                                    -->
		<!--=================================================================-->
		protected function creationCompleteHK_TitleWindow(event:FlexEvent):void 
		{
			this._initForm();
		}
		<!--=================================================================-->
		<!-- GridでのKeyDownが発生したとき                                   -->
		<!--=================================================================-->
       	override public function keyDownCell(event:KeyboardEvent):void
       	{			
		}
		
	    <!--
		************************************************************************
        ***  SubForm イベント
		************************************************************************
        -->
		<!--=================================================================-->
		<!-- 検索マークがクリックされた時の処理                              -->
		<!--=================================================================-->
		override public function clickHelp(uicCtrl:UIComponent):void 
		{
			return;
		}
		<!--=================================================================-->
		<!-- 子フォームが閉じられ、自フォームへFocusが戻ってきた時の処理     -->
		<!--=================================================================-->
		override public function closeSubWindow(
				tlwWindow:HK_TitleWindow, 
				uicInputControl:UIComponent
			) : void {
			
		}
		
 		<!--
		************************************************************************
		***  ボタンイベント
		************************************************************************
		-->
		<!--=================================================================-->
		<!-- 読込ボタンを押下した時の処理                                    -->
		<!--=================================================================-->
		private function _clickBtnAdd():void 
		{ 
            if (this.checkAllData() != 0){
                return;
            }
            var arrSelectedItems:Array = listTables.selectedItems;
            if (arrSelectedItems.length == 0){
            	_onDblClickList();
            	return;
            }else{
            	var tablenames:String="";
            	for (var i:int=0;i<arrSelectedItems.length-1;i++){
            		tablenames += arrSelectedItems[i]["tablename"] + ",";
            	}
            	tablenames += arrSelectedItems[arrSelectedItems.length-1]["tablename"];
            	addTablesToDiagram(tablenames);
            }
		}
		<!--=================================================================-->
		<!-- 終了ボタンを押下した時の処理                                    -->
		<!--=================================================================-->
		private function _clickBtnEnd():void 
		{			
			this.close();			
		}
		
		<!--
		************************************************************************
		***  Private メソッド
		************************************************************************
		-->
		<!--=================================================================-->
		<!-- 初期化処理                                                      -->
		<!--=================================================================-->
		private function _initForm():void
		{
			var arrTables:Array = new Array();
			if (this.helpCode["Tables"] != null){
				arrTables = this.helpCode["Tables"] as Array;
			}
			this.listTables.dataProvider = arrTables;
			this.setAllEnabled();
 		}
		<!--=================================================================-->
		<!-- Gridのデータチェック処理(.checkAllData()でも動作)               -->
		<!--=================================================================-->
		override public function checkInputDataGrid(
				grd:HK_DataGrid,
		        dgcActive:HK_DataGridCell,
			    numRowIndex:Number,
			    strDataField:String
			):String{
			return "";
		}
		<!--=================================================================-->
		<!-- Grid:1件のレコ一ドも入力されていない場合                        -->
		<!--=================================================================-->
         private function _checkIsBlankGrid():Boolean {
			return false;
         }
		<!--=================================================================-->
		<!-- 各コントロールのデータチェック処理(.checkAllData()でも動作)     -->
		<!--=================================================================-->
		override public function checkGridRemote(
					grd:HK_DataGrid, 
					numRowIndex:Number, 
					strDataField:String
				):String {
			return "";
		}
		<!--=================================================================-->
		<!-- [Grid]データベースとの照合終了処理                              -->
		<!--=================================================================-->
		override public function checkGridRemoteData(
					grd:HK_DataGrid, 
					numRowIndex:Number, 
					strDataField:String, 
					event:ResultEvent
			):String {
			
			return "";
		}
		
		<!--
		************************************************************************
		***  データベースアクセス
		************************************************************************
		-->
		<!--=================================================================-->
		<!-- 読込処理                                                        -->
		<!--=================================================================-->
		private function _onDblClickList():void
		{
			var item:Object = listTables.selectedItem;
			if (item){
				addTablesToDiagram(item["tablename"].toString());				
			}
		}
		//tablenames: list of table names separated by "," if have only one, it's is table name
		private function addTablesToDiagram(tablenames:String):void
		{
			var p:Object = this.owner;
			p["addTableToDiagram"](tablenames);	
		}		
    ]]>
</mx:Script>	
	<!--
	************************************************************************
	***  画面デザイン
	************************************************************************
	-->
	<hc:HK_Button	id="btnAdd"	label="ﾃｰﾌﾞﾙ追加"	
					click="_clickBtnAdd()" enableTime="readbefore" tabIndex="3" tabEnabled="true" shortCutKey="read" left="5" bottom="5" width="100"/>
	<hc:HK_Button	id="btnEnd" label="戻る"	focusEnabled="false"	icon2="return" functionKey="F12"
					click="_clickBtnEnd()" shortCutKey="end" tabIndex="11" right="5" bottom="5" width="95"/>
	<newList:CheckboxList id="listTables" labelField="description" left="0" right="0" top="0" bottom="37" color="#000000"
				itemRenderer="com.controls.checkbox.CheckBoxRenderer" 
				allowMultipleSelection="true" doubleClickEnabled="true" doubleClick="_onDblClickList()">
	</newList:CheckboxList>
</hc:HK_TitleWindow>
