			private function _PrintExcel_Start():void{
				var expReport:HK_Report = new HK_Report(this);
				
				var strReportName:String = "";
				strReportName = Report_List.selectedData;
				
	            expReport.logicClass = "hkc.HKC21200";
	            expReport.clearCondition();
				expReport.addCondition('A15_RptFormatCD', A15_RptFormatCD.text);
				expReport.addCondition('A15_RptFormatNM', A15_RptFormatNM.text);
				expReport.addCondition('User', this.userID);
				expReport.addCondition('Term', this.termID);
				expReport.addCondition('csvFileName', _strCsvFL);
				expReport.addCondition('SheetName', _strSheetFL);
				expReport.addCondition('ReportName', strReportName);

				if (_numSyoriFlg == 0){
			 		if (PreviewKB.selected == true) {
				    	expReport.printView();
			        } else {
				    	expReport.toPrinter();
			        }
				} else {
					expReport.toExcel();
				}
			}
			
		    <!--=================================================================-->
			<!-- 条件節とORDER BY句のSELECT文の作成処理                          -->
		    <!--=================================================================-->
			private function _create_SQL_String():void{
				var wSQL:String;
				var i:Number;
				var w:String;
				var strCol:String = "";
				var strAtai1:String = "";
				var strAtai2:String = "";
				var strShiki:String = "";
				var wValue1:String;
				var wValue2:String;
				var Col_List:String;
				var strColData:String = "";
				
				wSQL = "FROM " + Table_List.selectedData;
				/** +----------------------------------------------+ Where節の生成        */
				w = "";
				for(i = 0; i < spr_Jyoken.rowAllCount; i++){
					strColData = spr_Jyoken.cell(i, 'Column_Name').selectedData;
					if (strColData == null){ strColData = ""; }
					
					if (strColData != ""){
						if (w == ""){
							w = " WHERE "
						} else {
							w = w + spr_Jyoken.cell(i, 'Enzanshi').text + " ";
						}
						w = w + spr_Jyoken.cell(i,'Column_Name').selectedData;
						
						strAtai1 = _aryJyokenAtai[i]["Atai1"];
						strAtai2 = _aryJyokenAtai[i]["Atai2"];
						strShiki = spr_Jyoken.cell(i, 'Shiki').selectedData;
						
						/**  条件と項目のﾀｲﾌﾟによる条件値の編集を行う｡              */
						wValue1 = _Jyoken_Data_Set(strCol, strAtai1, strShiki);
						wValue2 = _Jyoken_Data_Set(strCol, strAtai2, strShiki);
						
						switch(spr_Jyoken.cell(i, 'Shiki').selectedData){
							case "0":  w = w + " = " + wValue1 + " ";  break;
							case "1":  w = w + " <> " + wValue1 + " ";  break;
							case "2":  w = w + " < " + wValue1 + " ";  break;
							case "3":  w = w + " <= " + wValue1 + " ";  break;
							case "4":  w = w + " > " + wValue1 + " ";  break;
							case "5":  w = w + " >= " + wValue1 + " ";  break;
							case "6":  w = w + " BETWEEN " + wValue1 + " AND " + wValue2 + " ";  break;
							case "7":  w = w + " LIKE " + wValue1 + " ";  break;
							case "8":  w = w + " LIKE " + wValue1 + " ";  break;
							default:  w = w + " ";  break;
						}
					}
				}
				wSQL = wSQL + w;
				/** +----------------------------------------------+ OrderBy節の生成        */
				var intCnt:Number = 0;
				var intMin:Number = 999;
				var intMax:Number = 0;
				var w1:String;
				for(i = 0; i < spr_Data.rowAllCount; i++){
					if (spr_Data.cell(i,'Sort').selected == true){
						w = spr_Data.cell(i,'Junjo').text;
						if (HK_Data.parseNum(w) < intMin){
							intMin = HK_Data.parseNum(w);
						}
						if (HK_Data.parseNum(w) > intMax){
							intMax = HK_Data.parseNum(w);
						}
						intCnt += 1;
					}
				}
				if (intCnt > 0){
					w1="";
					for(intCnt = intMin; intCnt <= intMax; intCnt++){
						for(i = 0; i < spr_Data.rowAllCount; i++){
							w = spr_Data.cell(i, 'Junjo').text;
							if (intCnt == HK_Data.parseNum(w)){
								if (w1 == ""){
									w1 = " ORDER BY "
								} else {
									w1 = w1 + ","
								}
								w1 = w1 + spr_Data.cell(i, 'Table_Col').text;
								if (spr_Data.cell(i, 'Syurui').selectedData == "1"){
									w1 = w1 + " DESC";
								}
								break;
							}
						}
					}
					wSQL = wSQL + w1;
				}
				wSQL = wSQL + ";";
				
				_strPrintExcel_SQL = wSQL;			/** SQL文を設定保存する｡     */
			}
		    <!--=================================================================-->
			<!-- 条件節の条件値の文字列編集　　                                  -->
		    <!--=================================================================-->
			private function _Jyoken_Data_Set(
						strCol:String, 
						strAtai:String, 
						strShiki:String
				):String{
				
				var strRet:String = "";
				var numIdx:Number = 0;
				
			    var strCol:String = spr_Data.cell(numIdx, 'Table_Col').text;
				var strWk:String = "";
				var strType:String = "";
				for (numIdx=0; numIdx < _aryTableCol.length; numIdx++) {
					strWk = _aryTableCol[numIdx]["Column_Name"];
					if (strWk == strCol){
						strType = _aryTableCol[numIdx]["Column_Type"];
						break;
					}
				}
				switch(strType){
					case "nvarchar":
					case "varchar":
					case "datetime":
					case "timestamp":
					case "char":
						switch(strShiki){
							case "7":
								strRet = "'" + strAtai + "%'";  break;
							case "8":
								strRet = "'%" + strAtai + "%'";  break;                    		
							default:
								strRet = "'" + strAtai + "'";  break;                    		
						}
						break;
					case "decimal":
					case "int":
					case "int2":
					case "int4":
					case "money":
					case "smallint":
					case "number":
						strRet = strAtai;  break;
				}
				return strRet;
			}
	    ]]>
	</mx:Script>

