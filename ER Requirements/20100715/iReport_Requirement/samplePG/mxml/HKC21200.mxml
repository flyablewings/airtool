<hc:HK_TitleWindow xmlns:mx="http://www.adobe.com/2006/mxml"
	xmlns:hc="HK_Common.HK_Control.*"
	xmlns:hs="HK_Common.HK_S2Flex2.*"
	xmlns:s2="http://www.seasar.org/s2flex2/mxml"
	creationComplete="creationCompleteHK_TitleWindow(event)"
	layout="absolute" width="914" height="626" title="帳票作成" styleMode="main" closingMessage="true">

	<hs:HK_S2Flex2Service id="HKC21200J" destination="HKC21200" owner="{this}"/>
	
	<mx:Script>
	    <![CDATA[
	    	import mx.containers.Grid;
	    	import mx.containers.Box;
			import HK_Common.HK_Control.HK_ControlCnst.ReadState;
			import mx.controls.*;
			import mx.collections.*;
			import mx.rpc.events.ResultEvent;
			import HK_Common.HK_S2Flex2.*;
			import HK_Common.HK_Control.*;
			import HK_Common.HK_Control.HK_ControlCnst.*;
			import HK_Common.HK_Data.*;
			import HK_Common.HK_IO.*;
			import mx.managers.PopUpManager;
			import mx.controls.dataGridClasses.*;
			import mx.core.UIComponent;
			import mx.events.FlexEvent;
		
			<!--
			************************************************************************
			***  Private 変数
			************************************************************************
			-->
			private var mdm:HK_ModuleManager = new HK_ModuleManager;
			private var _strUpdateDate:String;
			private var _numSyoriFlg:Number;		/** 処理の呼出元 0-印刷､1-Excel保存    */
			private var _intPrintNum_S:int;
			private var _intPrintNum_E:int;
			
			private var _aryTableCol:Array = new Array();		/** ﾃｰﾌﾞﾙ列名              */
			private var _aryReportCol:Array = new Array();		/** ﾚﾎﾟｰﾄﾙ列名             */
			private var _aryJyokenAtai:Array = new Array();	/** 条件節の値の格納用     */
			private var _strPrintExcel_SQL:String = "";		/** 印刷/Excel保存用SQL文  */
			private var _strCsvFL:String = ""; 				/** 印刷用csvﾌｧｲﾙ名        */
			private var _strSheetFL:String = ""; 				/** Excel保存用ｼｰﾄ名ﾌｧｲﾙ   */
		
			<!-- 
			************************************************************************
			***  Private 定数
			************************************************************************
			-->
			private const _csnumLblWidth:Number = 80;
			private const _csnumSprCountRow:Number = 15;
				
			<!--
			************************************************************************
			***  フォームイベント
			************************************************************************
			-->
		    <!--=================================================================-->
			<!-- フォームが表示された時の処理　　　　　　　　　　   　　　　　　 -->
		    <!--=================================================================-->
			private function creationCompleteHK_TitleWindow(event:FlexEvent):void {
				this._initForm();
				this._start_readTable_List();	/** ﾃｰﾌﾞﾙ情報とﾌｧｲﾙ情報の取得    */
			}
		    <!--=================================================================-->
			<!-- GridでのKeyDownが発生したとき                                   -->
		    <!--=================================================================-->
           	override public function keyDownCell(event:KeyboardEvent):void{
           		var numRow:Number;
           		var numCol:Number;
           		
           		switch(event.currentTarget.id){
           			case "spr_Data":
						if (event.keyCode == Keyboard.TAB || event.keyCode == Keyboard.ENTER){
							numRow = spr_Data.activeRowIndex;
							numCol = spr_Data.activeColumnIndex;
							if (numCol > 0){
								if (event.shiftKey){
									if (numRow != 0 || numCol != 1){
										spr_Data.moveCell(MoveCellType.PrevCol);
									}
								} else {
									if (numRow != spr_Data.rowAllCount-1 || numCol != spr_Data.columnAllCount-1){
										spr_Data.moveCell(MoveCellType.NextCol);
									}
								}
							}
						}
           				break;
           			case "spr_Jyoken":
						if (event.keyCode == Keyboard.TAB || event.keyCode == Keyboard.ENTER){
							numRow = spr_Jyoken.activeRowIndex;
							numCol = spr_Jyoken.activeColumnIndex;
							if (event.shiftKey){
								if (numRow != 0 || numCol != 0){
									spr_Jyoken.moveCell(MoveCellType.PrevCol);
								}
							} else {
								if (numRow == spr_Jyoken.rowAllCount-1 && numCol == spr_Jyoken.columnAllCount-1){
									spr_Jyoken.addRow(spr_Jyoken.rowAllCount);
									spr_Jyoken.moveCell(MoveCellType.NextCol);
								} else {
									spr_Jyoken.moveCell(MoveCellType.NextCol);
								}
							}
						}
           				break;
           		}
           	}
			
			<!--
			************************************************************************
		    ***  SubForm イベント
			************************************************************************
		    -->
		    <!--=================================================================-->
			<!-- 検索マークがクリックされた時の処理                              -->
		    <!--=================================================================-->
			override public function clickHelp(uicCtrl:UIComponent):void {
				var objHelpCode:Object;

				switch(uicCtrl.id){
					case A15_RptFormatCD.id:
						mdm.showWindow("HKC21210.swf", this, uicCtrl);
						break;
				}
				return;
			}
			<!--=================================================================-->
			<!-- 子フォームが閉じられ、自フォームへFocusが戻ってきた時の処理     -->
		    <!--=================================================================-->
			override public function closeSubWindow(
						tlwWindow:HK_TitleWindow, 
						uicInputControl:UIComponent
				) : void {
		
				if (this.helpCode != null){
					uicInputControl.setFocus();
					switch (uicInputControl.id){
						case A15_RptFormatCD.id:
							A15_RptFormatCD.text = this.helpCode["A15_RptFormatCD"];
							break;
					}
					uicInputControl.dispatchEvent(
						new KeyboardEvent(KeyboardEvent.KEY_DOWN, true, false, 0, Keyboard.ENTER)
					);
				}
				this.helpCode = null;
			}
				
			<!--
			************************************************************************
			***  ボタンイベント
			************************************************************************
			-->
		    <!--=================================================================-->
			<!-- 取消ボタンを押下した時の処理                                    -->
		    <!--=================================================================-->
			private function _clickBtnEscape():void {
				var msg:HK_MsgBox;
				
				if (this.readState != "before") {
					msg = new HK_MsgBox(StyleMode.MsgWarning, this, "ｸﾘｱ確認", MsgButton.YesNo);
					msg.message = "画面に表示しているデータを\u000d" + 
					 			  "クリアしてもよろしいですか？";
					msg.cmdYes = this._initForm;
					msg.open();					
				}else{
					this._initForm();
				}
			}
		    <!--=================================================================-->
			<!-- 読込ボタンを押下した時の処理                                    -->
		    <!--=================================================================-->
			private function _clickBtnRead():void { 
	            if (this.checkAllData() != 0){
	                return;
	            }
 				this._start_readA15_RptFormat();
			}
		    <!--=================================================================-->
			<!-- 書込ボタンを押下した時の処理                                    -->
		    <!--=================================================================-->
			private function _clickBtnStore():void { 
				var msg:HK_MsgBox;
	            if (this.checkAllData() != 0){
	                return;
	            }
	            if (_check_SprData_Table_Col() == false){
					msg = new HK_MsgBox(StyleMode.MsgWarning, this,"入力ミス", MsgButton.Ok);
					msg.message = "ﾃｰﾌﾞﾙ/ﾋﾞｭｰ項目が選択されていません。";
					msg.open();
	            	return 
	            }
		        this._start_storeA15_RptFormat();
			}
		    <!--=================================================================-->
			<!-- 削除ボタンを押下した時の処理                                    -->
	   		<!--=================================================================-->
			private function _clickBtnDelete():void { 
				var msg:HK_MsgBox;
			
				msg = new HK_MsgBox(StyleMode.MsgWarning, this, "削除確認", MsgButton.YesNo);
				
				msg.message = "削除してよろしいですか？\u000d\u000d" +
						      "　コード:" + A15_RptFormatCD.text + "\u000d" +
						      "　帳票名:" + A15_RptFormatNM.text;
				msg.cmdYes = this._start_deleteA15_RptFormat;
				msg.open();
			}
		    <!--=================================================================-->
			<!-- 印刷ボタンを押下した時の処理                                    -->
		    <!--=================================================================-->
			private function _clickBtnPrint( event:MouseEvent ):void { 
				var msg:HK_MsgBox;
				
	            if (this.checkAllData() != 0){
	                return;
	            }
	            if (_check_SprData_Table_Col() == false){
					msg = new HK_MsgBox(StyleMode.MsgWarning, this,"入力ミス", MsgButton.Ok);
					msg.message = "ﾃｰﾌﾞﾙ/ﾋﾞｭｰ項目が選択されていません。";
					msg.open();
	            	return 
	            }
	            _numSyoriFlg = 0;
		        this._start_Atai_Edit();
			}
		    <!--=================================================================-->
			<!-- Excel保存ボタンを押下した時の処理                               -->
		    <!--=================================================================-->
			private function _clickBtnExcel():void {
				var msg:HK_MsgBox;
	            if (this.checkAllData() != 0){
	                return;
	            }
	            if (_check_SprData_Table_Col() == false){
					msg = new HK_MsgBox(StyleMode.MsgWarning, this,"入力ミス", MsgButton.Ok);
					msg.message = "ﾃｰﾌﾞﾙ/ﾋﾞｭｰ項目が選択されていません。";
					msg.open();
	            	return 
	            }
	            _numSyoriFlg = 1;
		        this._start_Atai_Edit();
			}
		    <!--=================================================================-->
			<!-- 終了ボタンを押下した時の処理                                    -->
		    <!--=================================================================-->
			private function _clickBtnEnd():void {
				this.close();
			}
		    <!--=================================================================-->
			<!-- ﾚﾎﾟｰﾄ項目に対してﾃｰﾌﾞﾙ項目が選択されているかをﾁｪｯｸする処理      -->
		    <!--=================================================================-->
			private function _check_SprData_Table_Col():Boolean{
				var numIdx:Number = 0;
				var strCol:String;
				var strWk:String;
				var blnChk:Boolean = false;
				
				for (numIdx=0; numIdx < spr_Data.rowAllCount; numIdx++) {
			    	strCol = spr_Data.cell(numIdx, 'Table_Col').text;
			    	strWk = HK_Data.trim(strCol);
			    	if (strWk.length != 0){
			    		blnChk = true;
			    		break;
			    	}
			 	}
				return blnChk;
			}
			
			<!--
			************************************************************************
			***  カスタムメソッド
			************************************************************************
			-->
		    <!--=================================================================-->
			<!-- フォームの初期化処理                                            -->
		    <!--=================================================================-->
			private function _initForm():void{
				this.readState = ReadState.ReadBefore;
				this.setAllEnabled();
				this.clearAllError();
				this.clearAllData();
				this.helpCode = null;
				
				this._strUpdateDate = "";
				Table_List.selectedIndex = -1;
				Report_List.selectedIndex = -1;
				spr_Data.resetRow(10);
				spr_Jyoken.resetRow(5);
				
				A15_RptFormatCD.setFocus();
			}
			<!--=================================================================-->
			<!-- 各コントロールのデータチェック処理(.checkAllData()でも動作)     -->
			<!--=================================================================-->
			override public function checkInputData(uicCtrl:UIComponent):String { 
				switch (uicCtrl.id) {
					case Report_List.id:
						break;
					case Table_List.id:
						break;
					default:
						break;
				}
				return ""
			}
			<!--=================================================================-->
			<!-- データベースとの照合開始処理(.checkAllData()では動作しない)     -->
			<!--=================================================================-->
			override public function checkRemote(uicCtrl:UIComponent):String { 
				var objArgs:Object = new Object();
				var msg:HK_MsgBox;
				var strWk:String = "";
				var strMes:String = "";
				
				switch (uicCtrl.id) {
					case Report_List.id:
						if (Report_List.selectedIndex != -1){
							/** ﾚﾎﾟｰﾄの列名を取得してspr_Dataに表示する｡            */
							_readReport_Column();
						}
						break;
					case Table_List.id:
						if (Table_List.selectedIndex != -1){
							/** ﾃｰﾌﾞﾙの列名を取得してspr_Dataにｺﾝﾎﾞﾎﾞｯｸｽで表示する｡ */
							_readTable_Column();
						}
						break;
					default:
						break;
			    }
				return "";
			}
			
			<!--=================================================================-->
			<!-- データベースとの照合終了処理                                    -->
			<!--=================================================================-->
			override public function checkRemoteData(
						uicCtrl:UIComponent, 
						event:ResultEvent
				):String { 
				var expData:Array = event.result as Array;
				
				switch (uicCtrl.id){
					case Report_List.id:
					case Table_List.id:
						switch (expData[0][0]["status"]) {
							case "existdata":
								break;
							case "nodata":
							case "error":
								return expData[0][0]["info"]
								break;
						}
						break;
					default:
						break;
				}
				return "";
			}
			
		    <!--=================================================================-->
			<!-- Gridのデータチェック処理(.checkAllData()でも動作)               -->
		    <!--=================================================================-->
			override public function checkInputDataGrid(
						grd:HK_DataGrid,
			            dgcActive:HK_DataGridCell,
				        numRowIndex:Number,
				        strDataField:String
				) : String {
				switch(grd.id){
					case "spr_Data":
						switch (strDataField) {
							case "Junjo":
								if (grd.cell(numRowIndex,'Sort').selected == true){
									if (dgcActive.text == "") {
										return "順序を入力して下さい。";
									}
								}
								grd.cell(numRowIndex, 'Junjo').errorString = "";
								break;
							case "Syurui":
								if (grd.cell(numRowIndex,'Sort').selected == true){
									if (dgcActive.selectedData == "") {
										return "種類を指定して下さい。";
									}
								}
								grd.cell(numRowIndex, 'Syurui').errorString = "";
								break;
						}
						break;
					case "spr_Jyoken":
						var strColData:String;
						strColData = grd.cell(numRowIndex,'Column_Name').selectedData;
						if (strColData == null){ strColData = ""; }
						
						switch (strDataField) {
							case "Enzanshi":
								if (strColData != ""){
									if (numRowIndex > 0){
										if (dgcActive.selectedData == "") {
											return "演算子を指定して下さい。";
										}
									}
								}else{
									grd.cell(numRowIndex, 'Enzanshi').errorString = "";
									grd.cell(numRowIndex, 'Shiki').errorString = "";
									grd.cell(numRowIndex, 'Atai1').errorString = "";
									grd.cell(numRowIndex, 'Atai2').errorString = "";
								}
								grd.cell(numRowIndex, 'Enzanshi').errorString = "";
								break;
							case "Column_Name":
								if (strColData == ""){
									grd.cell(numRowIndex,'Enzanshi').selectedData = "";
									grd.cell(numRowIndex,'Shiki').selectedData = "";
									grd.cell(numRowIndex, 'Atai1').text = "";
									grd.cell(numRowIndex, 'Atai2').text = "";
								}
								break;
							case "Shiki":
								if (strColData != ""){
									if (dgcActive.selectedData == "") {
										return "条件式を指定して下さい。";
									}
								}
								grd.cell(numRowIndex, 'Shiki').errorString = "";
								break;
							case "Atai1":
								if (strColData != ""){
									if (dgcActive.text == "") {
										return "値１を入力して下さい。";
									}
								}
								grd.cell(numRowIndex, 'Atai1').errorString = "";
								break;
							case "Atai2":
								if (strColData != ""){
									if (grd.cell(numRowIndex,'Shiki').selectedData == "6"){
										if (dgcActive.text == "") {
											return "値２を入力して下さい。";
										}
									}
								}
								grd.cell(numRowIndex, 'Atai2').errorString = "";
								break;
						}
						break;
				}
				return "";
			}

			<!--
			************************************************************************
			***  データベースアクセス
			************************************************************************
			-->
		    <!--=================================================================-->
			<!-- テーブル情報 読込処理(ﾌｫｰﾑ表示時に使用)                         -->
		    <!--=================================================================-->
			private function _start_readTable_List():void{
				var objArgs:Object = new Object();
				this.HKC21200J.readTable_List(new Array(objArgs));
			}
			public function _onResult_readTable_List( event:ResultEvent ):void{
				var expData:Array = event.result as Array;
				var msg:HK_MsgBox;
				switch(expData[0][0]["status"]){
					case "existdata":
						Table_List.dataProvider = expData[1];
						_start_readFile_List();				/**　ﾌｧｲﾙ情報の取得   */
						break;
					case "nodata":
						break;
					case "error":
						this.closingMessage = false;
						msg = new HK_MsgBox(StyleMode.MsgError, this, "ＤＢエラー", MsgButton.Ok);
						msg.message = expData[0][0]["info"];
						msg.cmdOk = this._clickBtnEnd;
						msg.open();
						break;
				}
			}			
		    <!--=================================================================-->
			<!-- ファイル情報 読込処理(ﾌｫｰﾑ表示時に使用)                         -->
		    <!--=================================================================-->
			private function _start_readFile_List():void{
				var objArgs:Object = new Object();
				this.HKC21200J.readFile_List(new Array(objArgs));
			}
			public function _onResult_readFile_List( event:ResultEvent ):void{
				var expData:Array = event.result as Array;
				var msg:HK_MsgBox;

				switch(expData[0][0]["status"]){
					case "existdata":
						Report_List.dataProvider = expData[1];
						this._initForm();
						break;
					case "nodata":
						break;
					case "error":
						this.closingMessage = false;
						msg = new HK_MsgBox(StyleMode.MsgError, this, "ＤＢエラー", MsgButton.Ok);
						msg.message = expData[0][0]["info"];
						msg.cmdOk = this._clickBtnEnd;
						msg.open();
						break;
				}
			}			
		    <!--=================================================================-->
			<!-- 選択されたレポートの項目名を取得する処理 　　　　　　　         -->
		    <!--=================================================================-->
			private function _readReport_Column():void{
				var objArgs:Object = new Object();
		    	objArgs["Report_Name"] = Report_List.selectedData;
				this.HKC21200J.readReport_Column(new Array(objArgs));
			}
			public function _onResult_readReport_Column( event:ResultEvent ):void{
				var expData:Array = event.result as Array;
				var cmbData:Array = new Array;
				var msg:HK_MsgBox;
				
				switch(expData[0][0]["status"]){
					case "existdata":
						if (expData[1].length>0){
							_aryReportCol = new Array();				/** ﾚﾎﾟｰﾄ列名        */
							spr_Data.resetRow(0);
							for (var numIdx:Number=0; numIdx<expData[1].length; numIdx++) {
								var objData:Object = new Object();
								var strWk:String = expData[1][numIdx]["Column_Name"];
								objData["Column_Name"] = strWk;
					    		_aryReportCol.push(objData);				/** ﾚﾎﾟｰﾄ列名の保存  */
					    		
				        		if (numIdx == spr_Data.rowAllCount) {
									spr_Data.addRow(spr_Data.rowAllCount);
								}								
					    		spr_Data.cell(numIdx, "Report_Col").text = strWk;
							}
						}
						Report_List.errorString = "";
						Table_List.setFocus();
						break;
					case "nodata":
						break;
					case "error":
						this.closingMessage = false;
						msg = new HK_MsgBox(StyleMode.MsgError, this, "ＤＢエラー", MsgButton.Ok);
						msg.message = expData[0][0]["info"];
						msg.cmdOk = this._clickBtnEnd;
						msg.open();
						break;
				}
			}
		    <!--=================================================================-->
			<!-- ﾃｰﾌﾞﾙまたはﾋﾞｭｰに登録されている列名などの情報 読込処理          -->
		    <!--=================================================================-->
			private function _readTable_Column():void{
				var objArgs:Object = new Object();
		    	objArgs["Table_Name"] = Table_List.selectedData;
				this.HKC21200J.readTable_Column(new Array(objArgs));
			}
			public function _onResult_readTable_Column( event:ResultEvent ):void{
				var expData:Array = event.result as Array;
				var cmbData:Array = new Array;
				var msg:HK_MsgBox;
				
				switch(expData[0][0]["status"]){
					case "existdata":
						if (expData[1].length>0){
							_aryTableCol = new Array();		/** ﾃｰﾌﾞﾙ列名                  */
							cmbData = new Array();			/** ｺﾝﾎﾞﾎﾞｯｸｽ用の配列          */
					    	cmbData.push("");				/** ｺﾝﾎﾞの最初に空白を設定する */
							for (var numIdx:Number=0; numIdx<expData[1].length; numIdx++) {
								var objData:Object = new Object();
								objData["Column_Name"] = expData[1][numIdx]["Column_Name"];
								objData["Column_Type"] = expData[1][numIdx]["Column_Type"];
					    		_aryTableCol.push(objData);							/** ﾃｰﾌﾞﾙ列名の保存  */
						    	cmbData.push(expData[1][numIdx]["Column_Name"]); 	/** ｺﾝﾎﾞ用に列名を保存 */
							}
							var colIdx:int = spr_Data.getColumnIndexByField('Table_Col');
							HK_DataGridComboBox(spr_Data.columns[colIdx]).itemLabel = cmbData;
							HK_DataGridComboBox(spr_Data.columns[colIdx]).itemData = cmbData;
							
							colIdx = spr_Jyoken.getColumnIndexByField('Column_Name');
							HK_DataGridComboBox(spr_Jyoken.columns[colIdx]).itemLabel = cmbData;
							HK_DataGridComboBox(spr_Jyoken.columns[colIdx]).itemData = cmbData;
						}
						Report_List.errorString = "";
						break;
					case "nodata":
						break;
					case "error":
						this.closingMessage = false;
						msg = new HK_MsgBox(StyleMode.MsgError, this, "ＤＢエラー", MsgButton.Ok);
						msg.message = expData[0][0]["info"];
